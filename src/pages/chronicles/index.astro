import BaseLayout from "../../layouts/BaseLayout.astro";

const pageContent = "<customhtml><!-- Google tag (gtag.js) -->\n\n\n\n</customhtml><div class=\"content\"><div id=\"T4281391803\" page-url=\"menu_web\" class=\"page pinned pinned-top fixed\"><a id=\"menu_web\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><header class=\"header-web\" role=\"banner\">\n  <br>\n  <div class=\"header-web__inner\">\n    <a class=\"header-web__brand\" href=\"/\">THERE &amp; BACK AGAIN</a>\n\n    <nav aria-label=\"Primary\" class=\"header-web__nav\">\n      <a class=\"header-web__link\" href=\"/chronicles/\">CHRONICLES</a>\n      <a class=\"header-web__link\" href=\"/by-region/\">BY REGION</a>\n      <a class=\"header-web__link\" href=\"/about-the-traveller/\">THE TRAVELLER</a>\n    </nav>\n  </div>\n  <br>\n</header>\n\n<hr class=\"header-rule\"></bodycopy></div></div></div><div style=\"margin-top: 0px; margin-bottom: 0px;\" class=\"pages\"><div id=\"C3646697726\" page-url=\"chronicles\" class=\"page\"><a id=\"chronicles\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><div class=\"chronicles-header\">\n  <div class=\"page-label\">The full archive</div>\n  <h1 class=\"chronicles-title\">The <em>Chronicles</em></h1>\n</div>\n\n\n\n<div class=\"grid-section\" id=\"chronicles-grid\">\n  <div class=\"grid-label\">All Chronicles</div>\n\n  <div class=\"posts-grid\">\n    <a class=\"post-card\" href=\"/1-day-in-cordoba/\">\n      <div class=\"post-region\">Seville → Córdoba → Seville</div>\n      <h2 class=\"post-title\">1 Day in Córdoba: The City Between Empires</h2>\n      <p class=\"post-excerpt\">Where Rome, Islam, and Christendom built upon each other&#x27;s bones</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/10-days-in-sevilla/\">\n      <div class=\"post-region\">Spain · Andalucía · Seville · Córdoba · Granada</div>\n      <h2 class=\"post-title\">10 Days in Sevilla: Andalucía Without Rush</h2>\n      <p class=\"post-excerpt\">Ten days in southern Spain&#x27;s triumvirate of Moorish inheritance — using Seville as a fixed base, making the region reveal itself not by conquest, but by return.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/3-days-in-tangier-at-the-edge-of-two-worlds/\">\n      <div class=\"post-region\">Morocco · Fes → Tangier → Tarifa → Seville</div>\n      <h2 class=\"post-title\">3 Days in Tangier: At the Edge of Two Worlds</h2>\n      <p class=\"post-excerpt\">Three days in Tangier — the White City that looks toward Africa and Europe at once, and belongs wholly to neither.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/italy-morocco-seville-4-week-itinerary/\">\n      <div class=\"post-region\">Bologna · Rome · Marrakech · Rabat · Fes · Tangier · Seville</div>\n      <h2 class=\"post-title\">Italy, Morocco &amp; Seville 4 week Itinerary</h2>\n      <p class=\"post-excerpt\">Bologna · Rome · Marrakech · the Imperial Cities of Morocco · and across the Strait into Andalucía</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/san-marino-day-trip-guide/\">\n      <div class=\"post-region\">Bologna › Rimini › San Marino</div>\n      <h2 class=\"post-title\">San Marino Day Trip Guide</h2>\n      <p class=\"post-excerpt\">A day&#x27;s passage from Bologna to the mountain nation that time forgot to conquer</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/the-imperial-circuit-morocco-in-14-days/\">\n      <div class=\"post-region\">Morocco · Marrakech · Rabat · Fes · Tangier</div>\n      <h2 class=\"post-title\">The Imperial Circuit: Morocco in 14 Days</h2>\n      <p class=\"post-excerpt\">Marrakech to Rabat to Fes to Tangier — a standalone journey through Morocco&#x27;s old capitals, with the road running from red walls and desert light to medina shadow, Atlantic wind, and the northern strait.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/4-days-in-bologna/\">\n      <div class=\"post-region\">Italy · Emilia-Romagna · Bologna</div>\n      <h2 class=\"post-title\">4 Days in Bologna: The Fat City&#x27;s Table</h2>\n      <p class=\"post-excerpt\">A deeper guide to eating in Emilia-Romagna — the old country of ragù, mortadella, Parmigiano-Reggiano, and the settled conviction that lunch deserves reverence.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/six-days-in-rome-at-the-table-of-empires/\">\n      <div class=\"post-region\">Italy · Lazio · Rome</div>\n      <h2 class=\"post-title\">Six Days in Rome at the Table of Empires</h2>\n      <p class=\"post-excerpt\">From Pizzarium near the Vatican to carbonara at Roscioli, from the Colosseum at dawn to Trastevere at dusk — a chronicle of Rome, city of eternal hungers.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/1-day-in-sintra-the-mountain-of-romantic-follies/\">\n      <div class=\"post-region\">Europe · Portugal · Sintra</div>\n      <h2 class=\"post-title\">1 Day in Sintra: The Mountain of Romantic Follies</h2>\n      <p class=\"post-excerpt\">One day from Lisbon on a misty wooded hill where kings and an eccentric millionaire built their fantasies — palace as mood, not monument. Come ticketed.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/2-days-in-evora/\">\n      <div class=\"post-region\">Europe · Portugal · Alentejo</div>\n      <h2 class=\"post-title\">2 Days in Évora: Bones &amp; Roman Stones</h2>\n      <p class=\"post-excerpt\">A single overnight on the Alentejo plain — two thousand years of empire stacked inside one walled white town, with a chapel of bones at its heart.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/4-days-in-lagos-the-coast-of-golden-cliffs/\">\n      <div class=\"post-region\">Europe · Portugal · Algarve</div>\n      <h2 class=\"post-title\">4 Days in Lagos: The Coast of Golden Cliffs</h2>\n      <p class=\"post-excerpt\">Four days on the Algarve done at dawn — ochre cliffs and hidden coves before the heat, the grottoes by boat, and the land running out at Cabo de São Vicente.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/4-days-in-mondim-de-basto/\">\n      <div class=\"post-region\">Europe · Portugal · Tâmega Valley</div>\n      <h2 class=\"post-title\">4 Days in Mondim de Basto</h2>\n      <p class=\"post-excerpt\">Three nights in a mountain town nobody books — the case for stepping off the circuit, built around a wine festival, under a green summit and a white chapel.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/4-weeks-portugal-to-spain-by-rail-road/\">\n      <div class=\"post-region\">Europe · Portugal · Spain</div>\n      <h2 class=\"post-title\">4 Weeks Portugal to Spain by Rail &amp; Road</h2>\n      <p class=\"post-excerpt\">A month from Porto to Barcelona, almost entirely overland — port lodges and a mountain wine festival, fado and the Algarve cliffs, a chapel of bones, the oldest restaurant on earth, and Gaudí&#x27;s unfinished basilica. Each city the answer to the one before it.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/5-days-in-lisbon-itinerary/\">\n      <div class=\"post-region\">Europe · Portugal · Lisbon</div>\n      <h2 class=\"post-title\">5 Days in Lisbon Itinerary</h2>\n      <p class=\"post-excerpt\">Five days in the city of light and tile — read by climbing, from the castle hill to the river, with fado for the evenings and Sintra a train ride away.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/5-days-in-porto-the-city-the-river-built/\">\n      <div class=\"post-region\">Europe · Portugal · Douro</div>\n      <h2 class=\"post-title\">5 Days in Porto: The City the River Built</h2>\n      <p class=\"post-excerpt\">Five days in the city that turned a river into an industry — granite and gold, the climb up from Ribeira, port across the water, and a sunset for every evening.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/douro-valley-day-trip/\">\n      <div class=\"post-region\">Europe · Portugal · Douro</div>\n      <h2 class=\"post-title\">The Douro Valley — A Day Among the Terraced Vines</h2>\n      <p class=\"post-excerpt\">One day up the river from Porto — where the port is actually born, on hand-cut schist terraces in the oldest demarcated wine region on earth.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/1-day-in-cadiz/\">\n      <div class=\"post-region\">Europe · Andalucía · Cádiz</div>\n      <h2 class=\"post-title\">1 Day in Cádiz — At the Edge of the Known World</h2>\n      <p class=\"post-excerpt\">One day in Cádiz — Europe&#x27;s oldest city, three thousand years at the Atlantic shore</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/1-day-in-colonia-guell/\">\n      <div class=\"post-region\">Europe · Spain · Catalonia</div>\n      <h2 class=\"post-title\">1 Day in Colònia Güell</h2>\n      <p class=\"post-excerpt\">A quiet half-day from Barcelona to the unfinished crypt where Gaudí ran the upside-down string model that made the Sagrada Família possible. The workshop behind the masterpiece.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/1-day-in-figueres-girona/\">\n      <div class=\"post-region\">Europe · Spain · Catalonia</div>\n      <h2 class=\"post-title\">1 Day in Figueres &amp; Girona</h2>\n      <p class=\"post-excerpt\">One day north from Barcelona — the surrealist&#x27;s own museum-tomb in Figueres, then the stacked medieval old town of Girona on its painted river. The dream and the record, in that order.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/1-day-in-santiago-de-compostela/\">\n      <div class=\"post-region\">Europe · Spain · Galicia</div>\n      <h2 class=\"post-title\">1 Day in Santiago de Compostela</h2>\n      <p class=\"post-excerpt\">One day north from Porto — the cathedral, the Praza do Obradoiro, the swinging censer, and a Galician lunch at the end of the Camino</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/1-day-in-tarragona-sitges/\">\n      <div class=\"post-region\">Europe · Spain · Catalonia</div>\n      <h2 class=\"post-title\">1 Day in Tarragona &amp; Sitges</h2>\n      <p class=\"post-excerpt\">One day south from Barcelona — a Roman amphitheatre that opens straight onto the Mediterranean at Tarragona, then the white seaside ease of Sitges. The empire and the holiday on the same coast.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/2-days-in-caceres/\">\n      <div class=\"post-region\">Europe · Spain · Extremadura</div>\n      <h2 class=\"post-title\">2 Days in Cáceres: A Medieval City Held in Amber</h2>\n      <p class=\"post-excerpt\">A single overnight at the crossover into Spain — a walled old town so intact it doubles as King&#x27;s Landing, with storks nesting on the golden towers.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/3-days-in-madrid-the-capital-at-full-volume/\">\n      <div class=\"post-region\">Europe · Spain · Madrid</div>\n      <h2 class=\"post-title\">3 Days in Madrid: The Capital at Full Volume</h2>\n      <p class=\"post-excerpt\">Two dense nights in the loudest, hungriest city of the trip — the world&#x27;s oldest restaurant, a market lunch, the Arab baths, and Guernica in the quiet.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/4-days-in-valencia-itinerary/\">\n      <div class=\"post-region\">Europe · Spain · Valencia</div>\n      <h2 class=\"post-title\">4 Days in Valencia Itinerary</h2>\n      <p class=\"post-excerpt\">Four days along a missing river — a flood turned into a nine-kilometre garden, Gothic silk at one end and Calatrava&#x27;s white future at the other, and paella&#x27;s true home.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/7-days-in-barcelona/\">\n      <div class=\"post-region\">Europe · Spain · Catalonia</div>\n      <h2 class=\"post-title\">7 Days in Barcelona: Gaudí&#x27;s Unfinished Argument</h2>\n      <p class=\"post-excerpt\">The end of the line — seven days at the trip&#x27;s busiest base, read through Gaudí and the hill, with three day trips and a cathedral still rising after 140 years.</p>\n    </a>\n\n    <a class=\"post-card\" href=\"/2-days-in-fez-itinerary/\">\n      <div class=\"post-region\">Africa · Morocco · Imperial Circuit</div>\n      <h2 class=\"post-title\">2 Days in Fez Itinerary</h2>\n      <p class=\"post-excerpt\">Two days inside Fez el-Bali — the world&#x27;s oldest living medina, and the place that resists all description</p>\n    </a>\n  </div>\n</div></bodycopy></div></div></div></div></div>\n\t\t\n\t\n\n\n\n";
