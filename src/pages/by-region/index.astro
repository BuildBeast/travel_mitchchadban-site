const ACTIVE = "europe";
const EMPTY_STATE =
  "The road has not yet reached these shores. But the traveller is patient.";

const mapRegions = regions.map((r) => ({
  id: r.id,
  name: r.name,
  cx: r.cx,
  cy: r.cy,
  count: r.posts.length,
}));
---

<BaseLayout
  title="By Region — There & Back Again"
  description="Explore There & Back Again's travel chronicles by region on an interactive world map — from Portugal, Spain and Italy to Morocco and beyond."
  canonical="https://travel.mitchchadban.com/by-region/"
>
  <div class="region-header">
    <div class="page-label">Explore by region</div>
    <h1 class="region-title">The <em>Known World</em></h1>
    <p class="region-intro">
      A map of where the road has been. Choose a region to read its chronicles.
    </p>
  </div>

  <RegionMap regions={mapRegions} activeId={ACTIVE} />

  <div class="region-panels">
    {
      regions.map((r) => (
        <section
          class:list={["region-panel", { open: r.id === ACTIVE }]}
          id={`panel-${r.id}`}
          tabindex="-1"
          aria-labelledby={`panel-${r.id}-title`}
          hidden={r.id !== ACTIVE}
        >
          <div class="panel-header">
            <h2 class="panel-title" id={`panel-${r.id}-title`}>
              <em>{r.name}</em>
            </h2>
            <span class="panel-count">
              {r.posts.length > 0
                ? `${r.posts.length} ${r.posts.length === 1 ? "chronicle" : "chronicles"}`
                : "Not yet written"}
            </span>
          </div>

          {r.posts.length > 0 ? (
            <div class="panel-grid">
              {r.posts.map((p) => (
                <article class="panel-card">
                  <div class="card-region">{p.region}</div>
                  <h3 class="card-title">
                    <a href={p.href}>{p.title}</a>
                  </h3>
                  <p class="card-excerpt">{p.excerpt}</p>
                  {p.meta && p.meta.length > 0 && (
                    <div class="card-meta">
                      {p.meta.map((m, i) => (
                        <>
                          {i > 0 && <span class="dot-sep" aria-hidden="true" />}
                          <span>{m}</span>
                        </>
                      ))}
                    </div>
                  )}
                </article>
              ))}
            </div>
          ) : (
            <p class="panel-empty">{EMPTY_STATE}</p>
          )}
        </section>
      ))
    }
  </div>
</BaseLayout>

<script>
  // Map / region-switcher interaction. Progressive enhancement: the active
  // panel is already open in the server-rendered HTML.
  const hotspots = Array.from(document.querySelectorAll<HTMLElement>(".hotspot"));
  const switches = Array.from(
    document.querySelectorAll<HTMLElement>(".region-switch__btn"),
  );
  const panels = Array.from(
    document.querySelectorAll<HTMLElement>(".region-panel"),
  );

  function select(id: string | undefined, moveFocus: boolean) {
    if (!id) return;

    hotspots.forEach((h) => {
      const on = h.dataset.region === id;
      h.classList.toggle("active", on);
      h.setAttribute("aria-expanded", on ? "true" : "false");
    });
    switches.forEach((s) => {
      const on = s.dataset.region === id;
      s.classList.toggle("active", on);
      s.setAttribute("aria-pressed", on ? "true" : "false");
    });

    let active: HTMLElement | null = null;
    panels.forEach((p) => {
      const on = p.id === `panel-${id}`;
      p.classList.toggle("open", on);
      if (on) {
        p.removeAttribute("hidden");
        active = p;
      } else {
        p.setAttribute("hidden", "");
      }
    });

    if (active) {
      if (moveFocus) (active as HTMLElement).focus();
      if (window.innerWidth < 820) {
        (active as HTMLElement).scrollIntoView({
          behavior: "smooth",
          block: "start",
        });
      }
    }
  }

  // SVG hotspots: role="button" groups need explicit keyboard handling.
  hotspots.forEach((h) => {
    h.addEventListener("click", () => select(h.dataset.region, false));
    h.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Enter" || e.key === " " || e.key === "Spacebar") {
        e.preventDefault();
        select(h.dataset.region, true);
      }
    });
  });

  // Native <button> switches: click covers Enter/Space already.
  switches.forEach((s) => {
    s.addEventListener("click", () => select(s.dataset.region, false));
  });
</script>
