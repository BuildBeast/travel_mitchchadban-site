---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "There & Back Again",
      "alternateName": "There & Back Again — A Solo Travel Chronicle",
      "url": "https://travel.mitchchadban.com/",
      "description": "A solo travel chronicle blending literary travel stories, practical itineraries, food guides, and reflections from the road.",
      "inLanguage": "en-AU",
      "publisher": { "@type": "Organization", "name": "There & Back Again", "url": "https://travel.mitchchadban.com/" }
    }
  ]
};
const jsonLd = '<script type="application/ld+json">' + JSON.stringify(schema) + '<\/script>';
const pageContent = "<div style=\"margin-top: 0px; margin-bottom: 0px;\" class=\"pages\"><div id=\"T2989797706\" page-url=\"front-page\" class=\"page\"><a id=\"front-page\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><!--  HERO  -->\n<section class=\"hero\">\n  <div class=\"hero-ornament\">A solo travel chronicle</div>\n  <h1 class=\"hero-title\">There<br><em>&amp; Back</em><br>Again</h1>\n  <p class=\"hero-subtitle\">Tales written in the old manner — for those who travel not merely to arrive, but to be changed by the road.</p>\n  <a class=\"hero-cta\" href=\"/chronicles/\">Begin the Journey →</a>\n</section>\n\n<!--  TAGLINE  -->\n<div class=\"tagline-strip\">\n  <p>\"For what is travel, if not the art of gathering <span>stories</span> to warm the cold winters of ordinary time?\"</p>\n</div>\n\n<!--  POSTS GRID  -->\n<div class=\"section\">\n  <div class=\"section-label\">Latest Chronicles</div>\n  <div class=\"posts-grid\">\n\n    <a class=\"post-card\" href=\"/4-days-in-bologna/\">\n      <div class=\"post-region\">Italy · Europe</div>\n      <h2 class=\"post-title\">Bologna the Fat City’s Table</h2>\n      <p class=\"post-excerpt\">They came to Bologna on the second day of their wandering, when the light was the colour of old honey and the towers cast long shadows across the piazzas. No city had been so generous with its table, nor so quietly magnificent with its stones.</p>\n      <div class=\"post-meta\">\n        <span>4 days</span>\n        <span class=\"dot\"></span>\n        <span>September</span>\n      </div>\n    </a>\n\n    <a class=\"post-card\" href=\"/the-imperial-circuit-morocco-in-14-days/\">\n      <div class=\"post-region\">Morocco · Africa</div>\n      <h2 class=\"post-title\">The Imperial Circuit: Morocco</h2>\n      <p class=\"post-excerpt\">The medina swallowed the traveller whole — a labyrinth of spice and shadow older than any map they had brought with them.</p>\n      <div class=\"post-meta\">\n        <span>14 days</span>\n        <span class=\"dot\"></span>\n        <span>October</span>\n      </div>\n    </a>\n\n    <a class=\"post-card\" href=\"/coming-soon/\">\n      <div class=\"post-region\">Japan · Asia</div>\n      <h2 class=\"post-title\">Where the Temples Keep Their Silence</h2>\n      <p class=\"post-excerpt\">Kyoto in November is a city made entirely of farewells — each maple leaf a small, burning letter of departure.</p>\n      <div class=\"post-meta\">\n        <span>14 days</span>\n        <span class=\"dot\"></span>\n        <span>May</span>\n      </div>\n    </a>\n\n  </div>\n</div></bodycopy></div></div></div></div>";
---

<BaseLayout
  title="There & Back Again"
  description="There & Back Again is a solo travel blog blending literary travel stories, practical itineraries, food guides, and reflections from the road."
  canonical="https://travel.mitchchadban.com/"
>
  <Fragment slot="head" set:html={jsonLd} />
  <Fragment set:html={pageContent} />
</BaseLayout>
