import BaseLayout from "../../layouts/BaseLayout.astro";

const pageContent = "<div id=\"T4281391803\" page-url=\"menu_web\" class=\"page pinned pinned-top fixed\"><a id=\"menu_web\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><header class=\"header-web\" role=\"banner\">\n  <br>\n  <div class=\"header-web__inner\">\n    <a class=\"header-web__brand\" href=\"#\" rel=\"home-page\">THERE &amp; BACK AGAIN</a>\n\n    <nav aria-label=\"Primary\" class=\"header-web__nav\">\n      <a class=\"header-web__link\" href=\"/chronicles/\" rel=\"history\">CHRONICLES</a>\n      <a class=\"header-web__link\" href=\"/by-region/\" rel=\"history\">BY REGION</a>\n      <a class=\"header-web__link\" href=\"/about-the-traveller/\" rel=\"history\">THE TRAVELLER</a>\n    </nav>\n  </div>\n  <br>\n</header>\n\n<hr class=\"header-rule\"></bodycopy></div></div></div><div style=\"margin-top: 0px; margin-bottom: 0px;\" class=\"pages\"><div id=\"S0374504477\" page-url=\"5-days-in-lisbon-itinerary\" class=\"page\"><a id=\"5-days-in-lisbon-itinerary\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><!--  POST HERO  -->\n<section class=\"post-hero\">\n  <div class=\"post-route-strip\">\n    <span>Europe</span>&nbsp;· Portugal · Lisbon ·&nbsp;<span>Summer 2024</span>\n  </div>\n\n  <h1 class=\"post-hero-title\"><em>5 Days in Lisbon:</em> Seven Hills<br>&amp; the Sound of Fado</h1>\n  <p class=\"post-hero-sub\">Five days in the city of light and tile — read by climbing, from the castle hill to the river, with fado for the evenings and Sintra a train ride away.</p>\n  <div class=\"post-stats\">\n    <div class=\"stat\"><span class=\"stat-num\">5</span><span class=\"stat-label\">Days</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">7</span><span class=\"stat-label\">Hills</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">4</span><span class=\"stat-label\">Miradouros</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">~A$631</span><span class=\"stat-label\">5-Night Stay</span></div>\n  </div>\n</section>\n\n<!--  OPENING: THE ARRIVAL  -->\n<section class=\"opening-prose\">\n  <div class=\"narrative\">\n    <div class=\"prose\">\n      <p class=\"drop-cap\">Lisbon is a city you read by climbing. It is built on a fistful of hills above the Tagus — seven, the proud locals say, though the legs lose count somewhere past the fourth — and the only way to understand how the pieces fit is to keep going up: out of the grid of the lower town, up the worn stairs and the rattling funiculars and the <em>calçada</em> pavement polished to ice by three centuries of feet, until the city arranges itself below at a miradouro and you can finally see the shape of the thing. The light does the rest. Lisbon has a famous light, low and silver off the estuary, and it lands on the white limestone and the blue azulejo tiles and turns the whole city into something lit from the side, all surface and shadow, beautiful in a way that feels slightly melancholy even at noon.</p>\n      <p>That melancholy has a name here, and a sound. <em>Saudade</em> — the untranslatable Portuguese ache for something lost or never quite had — is the city's underlying key, and fado is the music written in it. After the green silence of the Basto hills the capital arrives as noise and light and appetite, trams and tiles and the smell of grilling sardines, but underneath the surface Lisbon keeps a sadness it is not ashamed of. Five days here, plus a day out to Sintra's painted mountain, and the city reveals itself the way it was built: one hill at a time, the view earned by the climb, the evening closed by a voice.</p>\n      <p>The traveller does not so much see Lisbon as ascend it.</p>\n    </div>\n  </div>\n</section>\n\n<!--  CHAPTER I  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter I</div>\n    <h2 class=\"chapter-name\"><em>The</em> Hills</h2>\n    <p class=\"chapter-epithet\">Alfama, the castle, and the city read from above</p>\n\n    <div class=\"prose\">\n      <p>Begin at the top, where the city began. The <strong>Castelo de São Jorge</strong> crowns the highest hill, a Moorish citadel turned royal fortress where Lisbon has been defended, ruled and surrendered for a thousand years, and from its ramparts the whole capital spills down to the river — the red roofs, the white domes, the great rust-coloured suspension bridge, the Tagus opening to the Atlantic. Below the castle the <strong>Alfama</strong> falls away in the city's oldest and most stubborn quarter, a Moorish tangle of lanes too steep and twisted for the cars or the planners to straighten, where the laundry hangs across the alleys and the locals still know each other and the <strong>tram 28</strong> grinds up through it all on rails worn silver. The earthquake of 1755 levelled most of Lisbon; Alfama, built on rock, survived, and so it survives as the city's memory of itself.</p>\n      <p>The way to read the city is from its <strong>miradouros</strong>, the terrace viewpoints set into the shoulders of the hills, each one a different angle on the same beauty. <strong>Portas do Sol</strong> and <strong>Santa Luzia</strong> look out over Alfama's rooftops to the river, tiled and bougainvillea-hung; <strong>São Pedro de Alcântara</strong>, reached by the 1885 Glória funicular, faces the castle across the valley of the lower town; and the <strong>Senhora do Monte</strong>, highest of them all in Graça, gives the widest sweep, the one to save for last light. Between them the city is all gradient and reward — every climb in Lisbon ends in a view, and every view costs a climb. That is the bargain the place is built on.</p>\n    </div>\n  </div>\n</section>\n\n<div class=\"beat\">Every climb in Lisbon ends in a view, and every view costs a climb.</div>\n\n<!--  CHAPTER II  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter II</div>\n    <h2 class=\"chapter-name\"><em>The</em> Voice</h2>\n    <p class=\"chapter-epithet\">Fado — an argument made about loss, not a show</p>\n\n    <div class=\"prose\">\n      <p>In the evening the city changes register. In the tiled back rooms of Alfama and the Bairro Alto, the lights go down, the chatter stops, a <em>guitarra portuguesa</em> picks out its silvery line, and a single singer — eyes closed, shawl pulled tight — begins to fold the whole weight of <em>saudade</em> into a voice. This is <strong>fado</strong>, the city's music, and the thing to understand about it is that it is not a performance staged for the tables. It is an argument, made with a voice, about loss — about the sea that took the sailors, the love that left, the life that turned out smaller than the dream of it. The good fado houses still enforce silence while the singer sings, because what is happening is closer to confession than to cabaret.</p>\n      <p>The traveller meets it on its own ground: at <strong>A Tasca do Chico</strong>, a cramped Bairro Alto tavern where amateur and professional <em>fadistas</em> take turns through the night over cheap red wine; at the <strong>Clube de Fado</strong> down in Alfama, more polished, where the singing comes with dinner and the guitars are masterful; and, by daylight, at the <strong>Museu do Fado</strong>, which traces the music's birth in these same poor riverside streets and keeps the memory of <strong>Amália Rodrigues</strong>, the voice that carried it to the world. Up the road the <strong>Panteão Nacional</strong> holds Amália's tomb among the kings and presidents — a singer of sailors' sorrows lying in state with the country's great, which tells you exactly how seriously Lisbon takes its sadness. Fado is not the soundtrack to the city. It is the city's argument with itself, sung aloud.</p>\n    </div>\n  </div>\n\n  <aside class=\"pull\">\n    <p>Fado is not a performance staged for the tables. It is an argument, made with a voice, about loss.</p>\n  </aside>\n</section>\n\n<!--  CHAPTER III  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter III</div>\n    <h2 class=\"chapter-name\"><em>The</em> River and the Discoveries</h2>\n    <p class=\"chapter-epithet\">Belém — the monastery, the tower, and the edge of the empire</p>\n\n    <div class=\"prose\">\n      <p>West along the Tagus, where the river widens toward the ocean, lies <strong>Belém</strong>, the quarter from which the empire sailed. It was from this shore that Vasco da Gama set out for India, and the wealth that came back built the two great monuments that still anchor the riverbank. The <strong>Mosteiro dos Jerónimos</strong> is late-Gothic Manueline architecture at full volume — a cloister carved with ropes, corals, artichokes and astrolabes, the whole iconography of a seafaring nation rendered in honey-coloured stone, with da Gama and the poet Camões entombed inside. A short walk along the water stands the <strong>Torre de Belém</strong>, the small fortified tower that guarded the harbour mouth and waved the ships out, its Moorish-Gothic balconies and stone rhinoceros the most photographed silhouette in Lisbon. Between them the <strong>Padrão dos Descobrimentos</strong> rears up like a stone ship's prow, Henry the Navigator at the front and the whole Age of Discovery lined up behind him, gazing out at the water that made and ruined the country.</p>\n      <p>It is a quarter that asks an honest question of the traveller — what the <em>Age of Discovery</em> cost the places it discovered — and Lisbon is beginning, slowly, to ask it too. But it also bakes the <strong>pastel de Belém</strong>, the original custard tart, sold warm and dusted with cinnamon from the same shop since 1837, and a stop there is not optional. Back in the centre, the <strong>Time Out Market</strong> in the old Mercado da Ribeira gathers the city's kitchens under one iron roof — a stand-up lunch of the country's best, from suckling pig to seafood, eaten elbow to elbow at the long tables. The empire's appetite, it turns out, outlasted the empire.</p>\n    </div>\n  </div>\n</section>\n\n<!--  CHAPTER IV  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter IV</div>\n    <h2 class=\"chapter-name\"><em>The</em> Lower Town</h2>\n    <p class=\"chapter-epithet\">Baixa and Chiado — the rebuilt grid and the small shops</p>\n\n    <div class=\"prose\">\n      <p>Down between the hills lies the <strong>Baixa</strong>, the lower town, and it is the one flat, orderly part of Lisbon — because it was built that way on purpose. When the 1755 earthquake, fire and tsunami destroyed the medieval centre and killed tens of thousands, the Marquês de Pombal rebuilt it from nothing as one of Europe's first planned grids: wide straight streets, uniform façades, the first anti-seismic timber cages hidden in the walls. The grid runs from the great riverside <strong>Praça do Comércio</strong>, through the triumphal <strong>Arco da Rua Augusta</strong>, up the pedestrian Rua Augusta to the Rossio. It is rational, handsome, and a little cold — the Enlightenment's answer to the Alfama's chaos, the two halves of the city's temperament laid side by side.</p>\n      <p>Climbing into the <strong>Chiado</strong>, the elegant old shopping quarter, the city softens again. Here is the dazzling Jesuit <strong>Igreja de São Roque</strong>, plain outside and, within, hiding the Chapel of St John the Baptist — assembled in Rome from lapis, gold and alabaster and shipped here, once the most expensive chapel in the world. And here are the small shops that are their own kind of monument: <strong>Livraria Bertrand</strong>, the oldest operating bookshop on earth, trading since 1732; <strong>Conserveira de Lisboa</strong>, where tinned sardines and mackerel come wrapped in bright waxed paper like gifts; <strong>Vellas Loreto</strong>, a candle-maker working since 1789. They are the unhurried, unbookable Lisbon — the city not as a list of sights but as a place that has simply kept doing its small, beautiful things for three hundred years.</p>\n    </div>\n  </div>\n</section>\n\n<div class=\"ornament\">· · · ✦ · · ·</div>\n\n<div class=\"beat\">One hill at a time, the view earned by the climb, the evening closed by a voice.</div>\n\n<!--  PRACTICAL: GETTING THERE & AROUND  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Getting There &amp; Around</div>\n    <div class=\"prac-dates\">Lisbon · Summer 2024</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Arriving</div>\n    <div class=\"prac-item\">Long-distance buses and trains come into <strong>Gare do Oriente</strong> (Calatrava's great steel canopy, worth a look in itself), about 20 minutes from the centre by metro.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Getting Around</div>\n    <div class=\"prac-item\">The <strong>metro</strong> is clean, cheap and useful for the long hops. Buy a rechargeable <strong>Viva Viagem</strong> card.</div>\n    <div class=\"prac-item\"><strong>Tram 28</strong> is the classic ride through Alfama and Graça (and a pickpocket's favourite — mind your bag); the <strong>Glória and Bica funiculars</strong> spare the steepest climbs. The <strong>Santa Justa Lift</strong> is more queue than it's worth.</div>\n    <div class=\"prac-item\"><strong>On foot</strong> — the core is walkable but punishingly steep and slick underfoot. Grippy shoes; the <em>calçada</em> is lethal in the rain.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Where to Base</div>\n    <div class=\"prac-item\">The trip's Airbnb sat on <strong>Rua da Vinha</strong>, on the Bairro Alto / Príncipe Real fringe: central, lively, loud at night. Roughly <strong>A$631 for the five-night stay</strong>.</div>\n  </div>\n</section>\n\n<!--  PRACTICAL: SITES & TICKETS  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Sites &amp; Tickets</div>\n    <div class=\"prac-dates\">Costs in AUD (€ locked)</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">The Hills &amp; Alfama</div>\n    <div class=\"prac-item\"><strong>Castelo de São Jorge</strong> — about <strong>A$25 (€15)</strong>. Go early or late; the midday queue and heat are real.</div>\n    <div class=\"prac-item\"><strong>Panteão Nacional</strong> — about <strong>A$7 (€4)</strong>; rooftop views and Amália's tomb. <strong>Museu do Fado</strong> — about <strong>A$8 (€5)</strong>.</div>\n    <div class=\"prac-item\"><strong>The miradouros</strong> — all free. The best value in the city.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Belém</div>\n    <div class=\"prac-item\"><strong>Mosteiro dos Jerónimos</strong> — about <strong>A$17 (€10)</strong>; church free, cloister ticketed. Long lines — book ahead.</div>\n    <div class=\"prac-item\"><strong>Torre de Belém</strong> — about <strong>A$10 (€6)</strong>. The exterior is the point. <strong>Padrão dos Descobrimentos</strong> — about <strong>A$7 (€4)</strong> for the rooftop.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Baixa &amp; Chiado</div>\n    <div class=\"prac-item\"><strong>Igreja de São Roque</strong> — church free; <strong>museum about A$4 (€2.50)</strong>.</div>\n  </div>\n</section>\n\n<!--  PRACTICAL: EATING & DRINKING  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Eating &amp; Drinking</div>\n    <div class=\"prac-dates\">The trip's table</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Quick &amp; Local</div>\n    <div class=\"prac-item\"><strong>O Trevo</strong> (Praça Luís de Camões) — the <em>bifana</em>, a humble pork sandwich Bourdain swore by. Stand at the counter, order a mini beer.</div>\n    <div class=\"prac-item\"><strong>Time Out Market</strong> — a stand-up tour of the city's kitchens under one roof; good for a first-night lunch.</div>\n    <div class=\"prac-item\"><strong>A Ginjinha</strong> (Largo de São Domingos) — a tiny standing bar pouring <em>ginja</em>, the sour-cherry liqueur, since 1840.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Dinner &amp; Fado</div>\n    <div class=\"prac-item\"><strong>A Tasca do Chico</strong> (Bairro Alto) — cheap wine, packed tables, amateur and pro fado through the night.</div>\n    <div class=\"prac-item\"><strong>100 Maneiras</strong> &amp; <strong>Cantinho do Avillez</strong> (Chiado) — the two serious dinners: Ljubomir Stanišić's tasting menu, and José Avillez's smart bistro. Book ahead.</div>\n    <div class=\"prac-item\"><strong>Clube de Fado</strong> (Alfama) — dinner and masterful fado in one of the old houses.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Sweet</div>\n    <div class=\"prac-item\"><strong>Pastéis de Belém</strong> — the original custard tarts, warm, with cinnamon. Non-negotiable.</div>\n  </div>\n</section>\n\n<!--  PRACTICAL: TIPS & WATCH-OUTS  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Tips &amp; Watch-outs</div>\n    <div class=\"prac-dates\">For the days in the city</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">On the Ground</div>\n    <div class=\"tip-row\"><strong>Read the city by climbing</strong> — and pace the climbs. Use the funiculars and tram 28 to save the legs, and chase the miradouros at golden hour.</div>\n    <div class=\"tip-row\"><strong>Mind the pickpockets</strong> on tram 28 and in the Baixa crowds. Bag in front, phone away.</div>\n    <div class=\"tip-row\"><strong>Book Jerónimos and the castle online.</strong> Belém's queues in summer can swallow an hour.</div>\n    <div class=\"tip-row\"><strong>Go to a real fado house, and be quiet.</strong> Silence while the singer sings is the etiquette and the whole point. Skip the touristy dinner-shows.</div>\n    <div class=\"tip-row\"><strong>The calçada is slippery</strong> — those beautiful mosaic pavements are treacherous wet or worn. Sensible shoes.</div>\n  </div>\n</section>\n\n<!--  VIATOR TOURS  -->\n<div class=\"tours\">\n  <div class=\"tours-label\">Guided Experiences — Lisbon</div>\n  <div class=\"tours-grid\">\n    <a class=\"tour-card\" href=\"https://www.viator.com/tours/Lisbon/Fado-Tour/d538-24774P7?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n      <div class=\"tour-type\">Fado &amp; Dinner</div>\n      <div class=\"tour-name\">Fado Experience: Alfama Walk, Dinner &amp; Live Show</div>\n      <div class=\"tour-meta\">The city's music on its home ground — a guided walk through Alfama and Mouraria, dinner, and a live fado house.</div>\n      <div class=\"tour-footer\">\n        <span class=\"tour-price\">From ~A$130</span>\n        <span class=\"tour-link-label\">View on Viator →</span>\n      </div>\n    </a>\n    <a class=\"tour-card\" href=\"https://www.viator.com/tours/Lisbon/Lisbon-Half-Day-Sightseeing-Tour-by-Electric-Tuk-Tuk/d538-25843P2?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n      <div class=\"tour-type\">Tuk-Tuk Tour</div>\n      <div class=\"tour-name\">Half-Day Sightseeing by Electric Tuk-Tuk</div>\n      <div class=\"tour-meta\">The seven hills without the climb — Alfama, the castle hill, Belém and the river by eco tuk-tuk.</div>\n      <div class=\"tour-footer\">\n        <span class=\"tour-price\">From ~A$90</span>\n        <span class=\"tour-link-label\">View on Viator →</span>\n      </div>\n    </a>\n    <a class=\"tour-card\" href=\"https://www.viator.com/tours/Lisbon/Lisbon-Food-and-Tuk-Tuk-Tour-with-Eating-Europe/d538-156455P2?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n      <div class=\"tour-type\">Food Tour</div>\n      <div class=\"tour-name\">Lisbon Food &amp; Tuk-Tuk Tour with Eating Europe</div>\n      <div class=\"tour-meta\">Codfish cakes, custard tarts and <em>ginja</em> through Baixa, Alfama and Mouraria — the back streets found for you.</div>\n      <div class=\"tour-footer\">\n        <span class=\"tour-price\">From ~A$160</span>\n        <span class=\"tour-link-label\">View on Viator →</span>\n      </div>\n    </a>\n  </div>\n</div>\n\n<!--  ITINERARY  -->\n<section class=\"itin-block\">\n  <div class=\"itin-inner\">\n    <div class=\"itin-block-title\">Five Days in Lisbon at a Glance</div>\n\n    <p class=\"itin-meta\">Shape: <strong>a base city of hills and river, read by climbing, with one day out to Sintra</strong>.</p>\n    <p class=\"itin-meta\">Stay: <strong>Rua da Vinha, Bairro Alto fringe, ~A$631 / 5 nights</strong>.</p>\n\n    <div class=\"itin-section-head\">Lisbon — the city and its day trip</div>\n    <div class=\"itin-days\">\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 1</span>Alfama &amp; the castle: São Vicente de Fora, Castelo de São Jorge, dinner and fado at A Tasca do Chico, the Bairro Alto and the São Pedro de Alcântara miradouro after dark.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 2</span>Belém: Time Out Market, Jerónimos, the Padrão dos Descobrimentos, the Torre de Belém, a pastel de Belém; dinner at 100 Maneiras, a ginjinha to finish.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 3</span>Baixa &amp; Chiado: São Roque, the Rua Augusta arch, MUDE, the Sé, the Panteão and the Fado Museum, down through Alfama; dinner at Cantinho do Avillez, the Portas do Sol miradouro at dusk.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 4</span>Day trip: <strong>Sintra</strong>. Dinner and fado at the Clube de Fado, last light from the Senhora do Monte.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 5</span>The small shops: Livraria Bertrand, Conserveira de Lisboa, Vellas Loreto — then the bus south to Lagos and the Algarve.</div>\n    </div>\n  </div>\n</section>\n\n<!--  CLOSING REFLECTION  -->\n<section class=\"post-closing\">\n  <div class=\"narrative\">\n    <div class=\"prose\">\n      <p>What the traveller carries away from Lisbon is not, in the end, a single building — not the carved cloister or the river tower or the castle on the hill, lovely as they are — but the <em>feeling</em> the city runs on: the silver light on the tiles, the ache under the surface, the way every effort of climbing is answered by a view and every bright evening carries, somewhere in it, a voice singing about loss. Lisbon is a beautiful city that has known decline and earthquake and empire and the loss of empire, and it has turned all of it into something to look at and something to sing, rather than something to hide.</p>\n      <p>The trams will still be grinding up through Alfama; the tarts will still be warm in Belém; the singer will still close her eyes in some tiled back room and fold the whole weight of <em>saudade</em> into a single held note. The traveller goes south to the Algarve with the city's light still on the backs of the eyes and its sadness, oddly, as comfort. Lisbon does not ask to be conquered. It asks only to be climbed, and listened to.</p>\n    </div>\n  </div>\n</section>\n\n<div class=\"beat\">But the road is ever onward.</div>\n\n<!--  FAQ  -->\n<section class=\"faq-block\">\n  <div class=\"faq-inner\">\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Is five days enough for Lisbon?</div>\n      <div class=\"faq-a\">Comfortably. Five days covers Alfama and the castle, Belém and the river, the Baixa and Chiado, a proper fado night, and still leaves a full day for Sintra. It is enough to read the city by its hills without rushing — and to slow down for the small shops and the miradouros.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">What is fado, and where should you hear it?</div>\n      <div class=\"faq-a\">Fado is Lisbon's traditional song — a melancholic music of longing (saudade) sung to the Portuguese guitar, born in the poor riverside quarters. Hear it in a real fado house in Alfama or the Bairro Alto, such as A Tasca do Chico or the Clube de Fado, where the room stays silent while the singer sings. The Museu do Fado is a good primer.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">How do you get around Lisbon's hills?</div>\n      <div class=\"faq-a\">On foot for the core, with help: the historic tram 28, the Glória and Bica funiculars, and the metro for longer hops. Buy a rechargeable Viva Viagem card. Wear grippy shoes — the mosaic calçada pavement is famously slippery.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Is Belém worth the trip from central Lisbon?</div>\n      <div class=\"faq-a\">Yes. Belém holds the Jerónimos Monastery and the Torre de Belém (both UNESCO sites), the Padrão dos Descobrimentos, and the original Pastéis de Belém custard tarts. It is about 20 minutes west along the river and easily a half to full day.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">When should you visit Lisbon?</div>\n      <div class=\"faq-a\">Spring and autumn are ideal — warm light, fewer crowds, kinder temperatures for the hills. Summer is hot and busy but full of festivals (the Santo António street parties in June are a highlight). Winter is mild, quiet and cheap, with the city's famous light at its softest.</div>\n    </div>\n  </div>\n</section>\n\n\n\n<!--  FURTHER READING  -->\n<section class=\"next-chronicles\">\n  <div class=\"narrative\">\n    <h2 class=\"chapter-name\" style=\"text-align:center; margin-bottom: 2.5rem;\"><em>Further</em> Reading</h2>\n    <div class=\"posts-grid\">\n      <a class=\"post-card\" href=\"/1-day-in-sintra-the-mountain-of-romantic-follies/\" rel=\"history\">\n        <div class=\"post-region\">Portugal · Sintra</div>\n        <div class=\"post-title\">Sintra: The Mountain of Romantic Follies</div>\n        <div class=\"post-excerpt\">The day trip into the painted mountain — palaces, fog and the Pena's mad colour, 40 minutes by train.</div>\n      <div class=\"post-meta\">1 day&nbsp;<span class=\"dot\"></span>&nbsp;Day Trip</div>\n      </a>\n      <a class=\"post-card\" href=\"/4-days-in-lagos-the-coast-of-golden-cliffs/\" rel=\"history\">\n        <div class=\"post-region\">Portugal · Algarve</div>\n        <div class=\"post-title\">Lagos: The Coast of Golden Cliffs</div>\n        <div class=\"post-excerpt\">South to the Atlantic edge — ochre sea-cliffs, grottoes and the end of the Age of Discovery's launch coast.</div>\n      <div class=\"post-meta\">4 days&nbsp;<span class=\"dot\"></span>&nbsp;City guide</div>\n      </a>\n      <a class=\"post-card\" href=\"/5-days-in-porto-the-city-the-river-built/\" rel=\"history\">\n        <div class=\"post-region\">Portugal · Douro</div>\n        <div class=\"post-title\">Porto: The City the River Built</div>\n        <div class=\"post-excerpt\">The northern counterweight — granite, gold and port, and the river that paid for all of it.</div>\n      <div class=\"post-meta\">1 day&nbsp;<span class=\"dot\"></span>&nbsp;Day Trip</div>\n      </a>\n    </div>\n  </div>\n</section></bodycopy></div></div></div></div>";
