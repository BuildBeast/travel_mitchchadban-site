const pageContent = "<div id=\"T4281391803\" page-url=\"menu_web\" class=\"page pinned pinned-top fixed\"><a id=\"menu_web\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><header class=\"header-web\" role=\"banner\">\n  <br>\n  <div class=\"header-web__inner\">\n    <a class=\"header-web__brand\" href=\"#\" rel=\"home-page\">THERE &amp; BACK AGAIN</a>\n\n    <nav aria-label=\"Primary\" class=\"header-web__nav\">\n      <a class=\"header-web__link\" href=\"/chronicles/\" rel=\"history\">CHRONICLES</a>\n      <a class=\"header-web__link\" href=\"/by-region/\" rel=\"history\">BY REGION</a>\n      <a class=\"header-web__link\" href=\"/about-the-traveller/\" rel=\"history\">THE TRAVELLER</a>\n    </nav>\n  </div>\n  <br>\n</header>\n\n<hr class=\"header-rule\"></bodycopy></div></div></div><div style=\"margin-top: 0px; margin-bottom: 0px;\" class=\"pages\"><div id=\"H2555606254\" page-url=\"san-marino-day-trip-guide\" class=\"page\"><a id=\"san-marino-day-trip-guide\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><!--  ============================================================\n     THERE AND BACK AGAIN — Page: San Marino Day Trip\n     Paste into Cargo 3 page code embed (body content only)\n     Nav and footer are pinned globally — exclude from this file\n     ============================================================  -->\n\n<!--  JSON-LD SCHEMA  -->\n<!-- <script>\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [\n    {\n      \"@type\": \"Article\",\n      \"headline\": \"San Marino Day Trip from Bologna: The World's Oldest Republic\",\n      \"description\": \"A literary travel guide to visiting San Marino as a day trip from Bologna via Rimini — covering the Three Towers, Guaita fortress, transport, costs, and practical tips for solo travellers.\",\n      \"author\": { \"@type\": \"Person\", \"name\": \"The Traveller\" },\n      \"publisher\": { \"@type\": \"Organization\", \"name\": \"There and Back Again\", \"url\": \"https://thereandbackagain.blog\" },\n      \"url\": \"https://thereandbackagain.blog/san-marino-day-trip\",\n      \"datePublished\": \"2025-01-01\",\n      \"inLanguage\": \"en\"\n    },\n    {\n      \"@type\": \"TravelGuide\",\n      \"name\": \"San Marino Day Trip from Bologna\",\n      \"description\": \"Complete guide to visiting San Marino as a day trip from Bologna, Italy — including Bonelli Bus transport from Rimini, Guaita Tower, the Three Towers, Palazzo Pubblico, and budget information.\",\n      \"url\": \"https://thereandbackagain.blog/san-marino-day-trip\",\n      \"touristType\": \"Solo traveller\",\n      \"itinerary\": {\n        \"@type\": \"ItemList\",\n        \"itemListElement\": [\n          { \"@type\": \"ListItem\", \"position\": 1, \"name\": \"Bologna Centrale — board Trenitalia to Rimini\" },\n          { \"@type\": \"ListItem\", \"position\": 2, \"name\": \"Rimini — Bonelli Bus to San Marino (Piazzale Calcigni)\" },\n          { \"@type\": \"ListItem\", \"position\": 3, \"name\": \"Guaita Tower (La Rocca) — oldest fortress on Monte Titano\" },\n          { \"@type\": \"ListItem\", \"position\": 4, \"name\": \"Sammarinese Museum of Ancient Arms — Cesta Tower\" },\n          { \"@type\": \"ListItem\", \"position\": 5, \"name\": \"Basilica di San Marino and Palazzo Pubblico\" },\n          { \"@type\": \"ListItem\", \"position\": 6, \"name\": \"Chiesa di San Francesco — paintings by Guercino and Raphael\" }\n        ]\n      }\n    },\n    {\n      \"@type\": \"FAQPage\",\n      \"mainEntity\": [\n        {\n          \"@type\": \"Question\",\n          \"name\": \"How do you get from Bologna to San Marino?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Take a Trenitalia train from Bologna Centrale to Rimini (approximately 1 hour, from around €10). From Rimini station, cross the road and buy a Bonelli Bus ticket from the tabaccheria near Burger King — approximately €6 one-way. The bus departs from outside the Napoleon Hotel and takes around 50 minutes, dropping you at Piazzale Calcigni in San Marino's old town.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"How much does it cost to visit San Marino from Bologna?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Budget approximately AUD $60–80 for the full day trip from Bologna, including the train to Rimini (from ~€10), Bonelli Bus return (€12), tower entry (~€8–10), lunch (~€12–15), and any souvenirs. The towers charge a small combined entry fee — check the official San Marino tourism site for current rates.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"Is San Marino worth visiting as a day trip?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Yes — San Marino is genuinely rewarding for a half-day. The UNESCO-listed old town is compact but historically rich, the views from the towers across the Adriatic plain are exceptional, and the novelty of visiting one of the world's oldest republics — and its smallest — makes it a memorable detour from Bologna's itinerary.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"How long do you need in San Marino?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Four to five hours is sufficient to walk the old town, visit Guaita Tower and the Museum of Ancient Arms, see the Basilica and Palazzo Pubblico, and have lunch. The Bonelli Bus runs only a few times per day, so plan your return carefully — check timetables at bonellibus.it before you go.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"Do you need a passport for San Marino?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"There is no border control between Italy and San Marino, so no passport check. However, bring your passport to the San Marino tourism office if you want a souvenir entry stamp — a popular keepsake for travellers. The stamp is available for a small fee.\"\n          }\n        }\n      ]\n    },\n    {\n      \"@type\": \"BreadcrumbList\",\n      \"itemListElement\": [\n        { \"@type\": \"ListItem\", \"position\": 1, \"name\": \"Home\", \"item\": \"https://thereandbackagain.blog\" },\n        { \"@type\": \"ListItem\", \"position\": 2, \"name\": \"Chronicles\", \"item\": \"https://thereandbackagain.blog/chronicles\" },\n        { \"@type\": \"ListItem\", \"position\": 3, \"name\": \"Europe\", \"item\": \"https://thereandbackagain.blog/chronicles#europe\" },\n        { \"@type\": \"ListItem\", \"position\": 4, \"name\": \"San Marino Day Trip from Bologna\", \"item\": \"https://thereandbackagain.blog/san-marino-day-trip\" }\n      ]\n    }\n  ]\n}\n</script> -->\n\n<!--  POST HERO  -->\n<section class=\"post-hero\">\n  <div class=\"post-route-strip\">\n    <span>Bologna</span>&nbsp;›&nbsp;<span>Rimini</span>&nbsp;›&nbsp;<span>San Marino</span>\n  </div>\n\n  <h1 class=\"post-hero-title\">San Marino: <em>Upon the Rock of the Oldest Republic</em>\n  </h1>\n\n  <p class=\"post-hero-sub\">A day's passage from Bologna to the mountain nation that time forgot to conquer</p>\n\n  <div class=\"post-stats\">\n    <div class=\"stat\">\n      <span class=\"stat-num\">1</span>\n      <span class=\"stat-label\">Day</span>\n    </div>\n    <div class=\"stat\">\n      <span class=\"stat-num\">301</span>\n      <span class=\"stat-label\">AD Founded</span>\n    </div>\n    <div class=\"stat\">\n      <span class=\"stat-num\">3</span>\n      <span class=\"stat-label\">Towers</span>\n    </div>\n    <div class=\"stat\">\n      <span class=\"stat-num\">739m</span>\n      <span class=\"stat-label\">Above Sea Level</span>\n    </div>\n  </div>\n</section>\n\n<!--  POST BODY  -->\n<div class=\"post-body\">\n\n  <!--  OPENING CHRONICLE  -->\n  <div class=\"opening-prose\">\n    <div class=\"prose\">\n      <p class=\"drop-cap\">There are nations that demand weeks of preparation, that require the ordering of visas and the booking of connections months in advance, that announce their grandeur before the traveller even departs. And then there is San Marino — which announces nothing, which sits quietly upon its improbable mountain, which has been sitting quietly upon its improbable mountain since the year 301 of the common era, and which has somehow outlasted every empire that ever looked up at it and thought: we should probably deal with that eventually.</p>\n\n      <p>The traveller arrived in Bologna with several days in hand and a map full of possibilities. Rome lay to the south. Venice shimmered to the northeast. But it was the small notation on the edge of the Emilia-Romagna region — this peculiar microstate pressed against the Italian hills like a barnacle on a cathedral wall — that pulled at something. Not the pull of grandeur. The pull of the curious. The pull of a place that has no right to still exist, and yet does.</p>\n\n      <p>San Marino is the world's oldest surviving republic, a UNESCO World Heritage Site, and a country so small you can walk its old town in an hour. A day trip from Bologna, accomplished by train and bus, deposits the traveller atop Monte Titano in time for lunch. It is, in every practical sense, a modest excursion. But modest in distance is not modest in feeling. To stand upon the Guaita Tower — that ancient fortress of dark stone clinging to the rock above the Adriatic plain — and to look out across the rooftops of a nation that has never fallen, is to feel something that the great and obvious cities rarely offer: the particular wonder of the small thing that endured.</p>\n    </div>\n  </div>\n\n  <!--  CHAPTER: THE JOURNEY OUT  -->\n  <div class=\"chapter-break\">\n    <div class=\"chapter-number\">Chapter I</div>\n    <h2 class=\"chapter-name\">The Steel Serpent to <em>Rimini</em></h2>\n    <p class=\"chapter-epithet\">On the morning rails of the Adriatic coast</p>\n  </div>\n\n  <div class=\"narrative\">\n    <div class=\"weather-badge\">\n      <span>☀️ September</span>\n      <span class=\"w-hi\">Hi 26°C</span>\n      <span class=\"w-lo\">Lo 17°C</span>\n    </div>\n\n    <div class=\"prose\">\n      <p>The steel serpent that rides the rails from Bologna Centrale to Rimini departs in its own unhurried way, as Italian trains sometimes do, and arrives on the Adriatic coast in just over an hour. Bologna recedes into its red-roofed world of arcades and ancient learning; the country opens out into flatter, more coastal terrain, the light changing as the sea approaches. Rimini itself holds little drama — it is a beach city, practical and seasonal — but it is the necessary door through which one must pass to reach the mountain republic beyond.</p>\n\n      <p>The traveller's instructions, received from prior reading, proved exact: exit the station, cross to the Burger King side of the road, and find the small tabaccheria tucked to its left. There, a Bonelli Bus ticket changes hands for six euros. The bus stop itself has migrated since older accounts were written — it now rests in front of the Napoleon Hotel, a short walk along the same street — and the traveller who arrives early enough to queue will be rewarded with a seat. The bus is not a luxury affair. It carries tourists and locals alike, its schedule sparse enough that the timing of one's Trenitalia arrival must be matched carefully against the posted timetable. But it climbs. And it climbs. And then, through the windows, the mountain appears.</p>\n    </div>\n\n    <div class=\"pull\">\n      <p>The first sight of San Marino from below is the towers — three dark fingers of ancient stone rising from the mountain's spine, impossibly placed, impossibly old, impossibly still standing.</p>\n    </div>\n\n    <div class=\"prose\">\n      <p>Monte Titano rises from the Adriatic plain without preamble or apology. The bus takes the mountain road in switchbacks, and with each turn the view behind expands — the flat agricultural land, the distant thread of the coast, the blue suggestion of the sea. At 739 metres, the peak claims its republic. The bus deposits its passengers at Piazzale Calcigni, just outside the walls of the old city, and the traveller steps out into air that is cooler and clearer than Bologna's, into a place where the twenty-first century has been politely asked to wait outside.</p>\n    </div>\n\n    <div class=\"practical\">\n      <div class=\"prac-header\">\n        <span class=\"prac-city\">📍 Bologna → Rimini → San Marino</span>\n        <span class=\"prac-dates\">🗓 Day Trip | September</span>\n      </div>\n\n      <div class=\"prac-section\">\n        <div class=\"prac-label\">Getting There — Bologna to Rimini</div>\n        <div class=\"prac-item\"><strong>Operator:</strong> Trenitalia — direct regional trains run frequently throughout the day from Bologna Centrale</div>\n        <div class=\"prac-item\"><strong>Travel time:</strong> ~1 hour (Regionale) to 1h 15min</div>\n        <div class=\"prac-item\"><strong>Cost:</strong> from ~€10 (book on trenitalia.com — earlier is cheaper). Validate your ticket at the yellow machines before boarding.</div>\n      </div>\n\n      <div class=\"prac-section\">\n        <div class=\"prac-label\">Getting There — Rimini to San Marino</div>\n        <div class=\"prac-item\"><strong>Operator:</strong> Bonelli Bus — the only bus service between Rimini and San Marino</div>\n        <div class=\"prac-item\"><strong>Tickets:</strong> Buy from the tabaccheria (tobacco shop) across from Rimini station, near Burger King. Do not go to the main bus station — they don't sell these tickets there. Buy paper tickets on the day; the online system is unreliable.</div>\n        <div class=\"prac-item\"><strong>Cost:</strong> ~€6 one-way / ~€12 return. Travel time: 50 minutes.</div>\n        <div class=\"prac-item\"><strong>Stop:</strong> Board in front of the Napoleon Hotel on the same street as Burger King. Alight at the final stop: Piazzale Calcigni.</div>\n        <div class=\"prac-item\"><strong>Schedule:</strong> Only 6 departures per day — check current timetable at bonellibus.it before you go and time your train to Rimini accordingly. Missing a bus means a long wait.</div>\n      </div>\n\n      <div class=\"prac-section\">\n        <div class=\"prac-label\">Tips &amp; Watch-Outs</div>\n        <div class=\"tip-row\">Queue early at the bus stop — boarding is not managed and can become a scramble. Being at the front matters for getting a seat.</div>\n        <div class=\"tip-row\">Take your passport to the San Marino tourism office (near the funicular) for an official entry stamp — a genuine keepsake, available for a small fee.</div>\n        <div class=\"tip-row\">Note the return bus time before you start exploring. Missing the last bus is not a crisis — taxis exist — but it adds unexpected cost.</div>\n      </div>\n    </div>\n  </div>\n\n  <!--  CHAPTER: THE REPUBLIC  -->\n  <div class=\"chapter-break\">\n    <div class=\"chapter-number\">Chapter II</div>\n    <h2 class=\"chapter-name\">Among the <em>Three Towers</em></h2>\n    <p class=\"chapter-epithet\">On the walls of a nation that refused to fall</p>\n  </div>\n\n  <div class=\"narrative\">\n    <div class=\"prose\">\n      <p>San Marino's old town is small enough that it can be walked end to end in twenty minutes, and rich enough in history that those twenty minutes, if attended to properly, can take the better part of an afternoon. The cobblestone streets wind between medieval buildings in pale stone, past souvenir shops — which skew, with some enthusiasm, toward replica crossbows and antique-style weaponry, San Marino having a long tradition of archery — and up toward the ridge of Monte Titano where the three towers stand against whatever sky the day has offered.</p>\n\n      <p>The first tower, Guaita, is the oldest and the largest, and it is the one that appears in every photograph of the republic — pentagonal, battlemented, set directly upon the mountain rock without foundations as though it grew there. The word Guaita means \"to guard,\" borrowed from an older Germanic tongue, and guarding is precisely what it has done since the eleventh century. The traveller who climbs it earns the view: the whole city below, the Apennine mountains to the west, the Adriatic plain stretching east toward the sea, and on a clear day the sea itself, a silver line at the world's edge. Two mortars, gifts of a nineteenth-century Italian king, stand in the courtyard. Former garrisons once imprisoned within these walls still carry the dim weight of that history.</p>\n    </div>\n\n    <div class=\"ornament\">· · · ✦ · · ·</div>\n\n    <div class=\"prose\">\n      <p>The second tower, Cesta, houses the Sammarinese Museum of Ancient Arms — some two thousand pieces of medieval armour and weaponry gathered across four rooms, a collection that rewards those with patience for the particular poetry of a well-made gauntlet or the geometry of a crossbow's mechanism. From its walls, the view shifts: the second tower shows the plain that stretches toward the Adriatic, the mountains, the spine of the republic's own ridge. The third tower, Montale, stands apart and is visible but not open to visitors — it holds itself at a private distance, as ruins sometimes will.</p>\n\n      <p>Below the towers, the Basilica di San Marino stands in neoclassical composure, its eight Corinthian columns keeping a quiet vigil over Piazza Domus Plebis. Built in 1836 on the site of a seventh-century church, it houses relics of Saint Marinus himself — the stonemason from Croatia who fled Roman persecution, was given a mountain by a woman whose son he had healed, and founded, from that act of refuge, an institution that outlasted every Roman emperor, every medieval duchy, every modern fascism that came looking at its walls. The Palazzo Pubblico, seat of the republic's government since 1894, stands nearby in its battlemented dignity — a building that has managed to look both official and slightly theatrical since the day it was built, which is perhaps appropriate for a country that is itself a kind of ongoing theatre of improbability.</p>\n    </div>\n\n    <div class=\"pull\">\n      <p>For what endures in San Marino is not merely stone — it is the stubborn, quietly radical idea that a small thing, if it refuses loudly enough to be absorbed, need not be.</p>\n    </div>\n\n    <div class=\"prose\">\n      <p>Lunch was taken in the old town, as it ought to be. San Marino sits in the Emilia-Romagna region, and the regional dishes follow the traveller up the mountain. A piadina — the soft flatbread of the Romagna coast, filled with squacquerone cheese and prosciutto and served warm from a griddle — is the correct meal for this altitude and this hour. Simple, specific, the kind of food that asks nothing of you except that you eat it without ceremony and feel, briefly, entirely correct about where you are.</p>\n    </div>\n\n    <div class=\"practical\">\n      <div class=\"prac-header\">\n        <span class=\"prac-city\">📍 San Marino — Old Town</span>\n        <span class=\"prac-dates\">🗓 Half-Day | 4–5 Hours</span>\n      </div>\n\n      <div class=\"prac-section\">\n        <div class=\"prac-label\">What to See</div>\n        <div class=\"prac-item\"><strong>Guaita Tower (La Rocca / First Tower)</strong> — the oldest and most iconic fortress. Allow 1 hour. Salita alla Rocca.</div>\n        <div class=\"prac-item\"><strong>Museum of Ancient Arms (Cesta / Second Tower)</strong> — 2,000 pieces of medieval weaponry. Allow 30 minutes. Worth it if you have an interest in medieval history.</div>\n        <div class=\"prac-item\"><strong>Basilica di San Marino</strong> — neoclassical church on Piazza Domus Plebis, housing relics of the republic's founder. Free entry, 20 minutes.</div>\n        <div class=\"prac-item\"><strong>Palazzo Pubblico</strong> — the government building on Piazza della Libertà. Worth a look from the outside; small museum inside.</div>\n        <div class=\"prac-item\"><strong>Chiesa di San Francesco</strong> — 14th-century church housing paintings attributed to Guercino and Raphael in its adjacent museum.</div>\n      </div>\n\n      <div class=\"prac-section\">\n        <div class=\"prac-label\">Where to Eat</div>\n        <div class=\"prac-item\"><strong>Cantina di Bacco</strong> — Piazzetta Giuseppe Garibaldi. The day trip's natural lunch stop: local wine, regional dishes, well-placed in the old town's heart.</div>\n        <div class=\"prac-item\"><strong>Piadina, anywhere</strong> — the regional flatbread of Romagna. With squacquerone and prosciutto, served warm. Order this. ~€6–8.</div>\n      </div>\n\n      <div class=\"prac-section\">\n        <div class=\"prac-label\">Entry Costs</div>\n        <div class=\"prac-item\">Towers and museums charge a small combined entry fee — typically €8–10 for the major towers. Check visitsanmarino.com for current rates.</div>\n        <div class=\"prac-item\">Passport stamp at the tourism office: small fee, absolutely worth it as a keepsake.</div>\n      </div>\n\n      <div class=\"prac-section\">\n        <div class=\"prac-label\">Budget Snapshot</div>\n        <div class=\"budget-grid\">\n          <div class=\"budget-cell\">\n            <div class=\"budget-cat\">Train (rtn)</div>\n            <div class=\"budget-val\">~A$25</div>\n          </div>\n          <div class=\"budget-cell\">\n            <div class=\"budget-cat\">Bus (rtn)</div>\n            <div class=\"budget-val\">~A$20</div>\n          </div>\n          <div class=\"budget-cell\">\n            <div class=\"budget-cat\">Entry fees</div>\n            <div class=\"budget-val\">~A$16</div>\n          </div>\n          <div class=\"budget-cell\">\n            <div class=\"budget-cat\">Lunch</div>\n            <div class=\"budget-val\">~A$22</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"prac-section\">\n        <div class=\"prac-label\">Tips &amp; Watch-Outs</div>\n        <div class=\"tip-row\">San Marino is tax-free — electronics, perfume, and Italian brands are cheaper here than in Italy. Worth browsing if you're in the market.</div>\n        <div class=\"tip-row\">San Marino euro coins are collectors' items. Pick one up at the post office or any shop — they are legal tender in Italy too.</div>\n        <div class=\"tip-row\">The funicular runs from Borgo Maggiore (lower town) up to the old city — useful if you want to vary your route down.</div>\n      </div>\n    </div>\n\n    <!--  VIATOR TOUR BLOCK  -->\n    <div class=\"tours\">\n      <div class=\"tours-label\">Guided Experiences in San Marino</div>\n      <div class=\"tours-grid\">\n\n        <a class=\"tour-card\" href=\"https://www.viator.com/tours/San-Marino/San-Marino-Private-Walking-Tour/d21911-255735P1?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n          <div class=\"tour-type\">Private Tour</div>\n          <div class=\"tour-name\">San Marino Private Walking Tour</div>\n          <div class=\"tour-meta\">3 hours · UNESCO historic centre, Guaita Tower, panoramic views</div>\n          <div class=\"tour-footer\">\n            <span class=\"tour-price\">From ~USD $60</span>\n            <span class=\"tour-link-label\">Via Viator →</span>\n          </div>\n        </a>\n\n        <a class=\"tour-card\" href=\"https://www.viator.com/tours/San-Marino/Guided-Walking-Tour-of-San-Marino-Historic-Centre/d21911-255735P2?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n          <div class=\"tour-type\">Guided Walk</div>\n          <div class=\"tour-name\">Historic Centre Walking Tour</div>\n          <div class=\"tour-meta\">3 hours · Small group · Old town streets, towers, local anecdotes</div>\n          <div class=\"tour-footer\">\n            <span class=\"tour-price\">From ~USD $35</span>\n            <span class=\"tour-link-label\">Via Viator →</span>\n          </div>\n        </a>\n\n        <a class=\"tour-card\" href=\"https://www.viator.com/tours/Bologna/Day-Trip-from-Bologna-to-San-Marino/d791-131155P69?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n          <div class=\"tour-type\">Day Trip</div>\n          <div class=\"tour-name\">Bologna to San Marino Day Trip</div>\n          <div class=\"tour-meta\">Full day · Private transfer from Bologna, guided visit of Monte Titano</div>\n          <div class=\"tour-footer\">\n            <span class=\"tour-price\">From ~USD $120</span>\n            <span class=\"tour-link-label\">Via Viator →</span>\n          </div>\n        </a>\n\n      </div>\n    </div>\n  </div>\n\n  <!--  BEAT  -->\n  <div class=\"beat\">But the road is ever onward.</div>\n\n  <!--  CLOSING CHRONICLE  -->\n  <div class=\"post-closing\">\n    <div class=\"narrative\">\n      <div class=\"prose\">\n        <p>The bus back to Rimini departs from the same square where it arrived, and the traveller who has spent the afternoon on the mountain boards it with a particular feeling — not quite the satisfaction of a great city absorbed, not quite the daze of an overwhelming museum day, but something more specific: the quiet pleasure of a small country, visited properly. San Marino is not a destination that demands superlatives. It does not need to be called the most beautiful place in Italy, or the most dramatic, or the most moving. It is, simply and remarkably, the oldest. And age, in a landscape littered with ancient things, is still capable of surprising.</p>\n\n        <p>The towers diminish behind the bus as it descends the mountain. The Adriatic plain opens up again. Rimini, then the train, then Bologna's red rooftops — the traveller returns to a city of greater size and lesser stubbornness, carrying nothing heavier than a passport stamp, a euro coin, and the memory of a view from a tower that has been watching the world since before most of the world's nations were imagined. Some things are worth the detour. San Marino, old and small and entirely itself, is one of them.</p>\n\n        <p>For what is travel, if not the art of being surprised by the things you did not think to expect?</p>\n      </div>\n    </div>\n  </div>\n\n</div>\n\n<!--  ITINERARY BLOCK  -->\n<div class=\"itin-block\">\n  <div class=\"itin-inner\">\n    <div class=\"itin-block-title\">The Day at a Glance</div>\n\n    <div class=\"itin-meta\"><strong>Trip:</strong> Bologna → Rimini → San Marino (return)</div>\n    <div class=\"itin-meta\"><strong>Duration:</strong> One day</div>\n    <div class=\"itin-meta\"><strong>Best time to go:</strong> April–June or September–October (comfortable temperatures, fewer summer crowds)</div>\n    <div class=\"itin-meta\"><strong>Travelled from:</strong> Bologna, Italy</div>\n\n    <div class=\"itin-section-head\">Day Schedule</div>\n    <div class=\"itin-days\">\n      <div class=\"itin-day-row\">\n        <span class=\"itin-day-num\">Morning</span>\n&nbsp; &nbsp; &nbsp; &nbsp; Bologna Centrale → Trenitalia to Rimini (~1 hr). Buy Bonelli Bus ticket at tabaccheria. Board bus to San Marino (~50 min).\n &nbsp; &nbsp; &nbsp;</div>\n      <div class=\"itin-day-row\">\n        <span class=\"itin-day-num\">Late Morning</span>\n&nbsp; &nbsp; &nbsp; &nbsp; Arrive Piazzale Calcigni. Walk to Guaita Tower — climb for views. Museum of Ancient Arms (Cesta Tower).\n &nbsp; &nbsp; &nbsp;</div>\n      <div class=\"itin-day-row\">\n        <span class=\"itin-day-num\">Midday</span>\n&nbsp; &nbsp; &nbsp; &nbsp; Lunch — Cantina di Bacco or piadina from any local spot. Passport stamp at tourism office.\n &nbsp; &nbsp; &nbsp;</div>\n      <div class=\"itin-day-row\">\n        <span class=\"itin-day-num\">Afternoon</span>\n&nbsp; &nbsp; &nbsp; &nbsp; Basilica di San Marino. Palazzo Pubblico. Chiesa di San Francesco. Browse old town. Collect euro coin.\n &nbsp; &nbsp; &nbsp;</div>\n      <div class=\"itin-day-row\">\n        <span class=\"itin-day-num\">Return</span>\n&nbsp; &nbsp; &nbsp; &nbsp; Bus from Piazzale Calcigni back to Rimini Stazione. Alight at Rimini FF.SS. (not the final stop). Train to Bologna.\n &nbsp; &nbsp; &nbsp;</div>\n    </div>\n\n    <div class=\"itin-section-head\">Total Budget Estimate (from Bologna)</div>\n    <div class=\"grand-total-block\">\n      <div class=\"grand-total-grid\">\n        <div class=\"grand-line\"><strong>Train return (Bologna–Rimini)</strong>&nbsp;~AUD $25</div>\n        <div class=\"grand-line\"><strong>Bonelli Bus return</strong>&nbsp;~AUD $20</div>\n        <div class=\"grand-line\"><strong>Tower entry</strong>&nbsp;~AUD $16</div>\n        <div class=\"grand-line\"><strong>Lunch &amp; drinks</strong>&nbsp;~AUD $22</div>\n        <div class=\"grand-line\"><strong>Incidentals / passport stamp / coin</strong>&nbsp;~AUD $10</div>\n      </div>\n      <div class=\"grand-total-num\">Estimated total: ~AUD $93</div>\n    </div>\n\n    <div class=\"itin-section-head\">Getting Around — Key Notes</div>\n    <div class=\"transport-note\"><strong>Train:</strong> Trenitalia direct from Bologna Centrale to Rimini. Book at trenitalia.com. Validate your ticket before boarding.</div>\n    <div class=\"transport-note\"><strong>Bus:</strong> Bonelli Bus — bonellibus.it for current timetable. Only six departures per day; plan train arrival accordingly. Buy paper tickets from the tabaccheria near Burger King, not online.</div>\n    <div class=\"transport-note\"><strong>On the mountain:</strong> Everything in the old town is walkable. The funicular connects Borgo Maggiore (lower town) to the historic centre if needed.</div>\n    <div class=\"transport-note\"><strong>Return bus stop:</strong> Catch the bus home from Piazzale Calcigni — the same stop you were dropped at. Alight at Rimini Stazione (Rimini FF.SS.), not the final stop of Piazza Marvelli.</div>\n  </div>\n</div>\n\n<!--  FAQ BLOCK  -->\n<div class=\"faq-block\">\n  <div class=\"faq-inner\">\n    <div class=\"itin-block-title\">Questions from the Road</div>\n\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">How do you get from Bologna to San Marino?</div>\n      <div class=\"faq-a\">Take a Trenitalia train from Bologna Centrale to Rimini (approximately 1 hour, from ~€10). From Rimini station, cross the road and buy a Bonelli Bus ticket from the tabaccheria near Burger King — €6 one-way. The bus takes 50 minutes to Piazzale Calcigni in San Marino's old town. Check the Bonelli Bus timetable at bonellibus.it before you go — there are only six trips per day.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Is San Marino worth visiting as a day trip from Bologna?</div>\n      <div class=\"faq-a\">Yes, genuinely. The UNESCO-listed old town is compact but historically extraordinary, the views from Guaita Tower across the Adriatic plain are exceptional, and visiting the world's oldest republic — a nation that has outlasted every empire that ever threatened it — is a genuinely memorable experience. Four to five hours on the mountain is enough. Budget the full day for travel and you'll return to Bologna by early evening, satisfied.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">How much does it cost to visit San Marino from Bologna?</div>\n      <div class=\"faq-a\">Budget around AUD $90–100 for the full day, including the Trenitalia train return (~AUD $25), Bonelli Bus return (~AUD $20), tower entry fees (~AUD $16), and lunch (~AUD $22). San Marino is also tax-free, so electronics and Italian brands are cheaper here than in Italy proper — factor that in if you're tempted to shop.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Do you need a passport to visit San Marino?</div>\n      <div class=\"faq-a\">There is no border control between Italy and San Marino, so no passport check. However, bring your passport to the San Marino tourism office — located near the funicular — where you can get an official souvenir stamp for a small fee. It's one of the better keepsakes available on the mountain.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">What is the best time to visit San Marino?</div>\n      <div class=\"faq-a\">April to June and September to October are ideal — comfortable temperatures, clear views from the towers, and fewer crowds than July and August. Summer brings festivals and local events but also significantly more visitors to the compact old town. Avoid peak summer midday if possible.</div>\n    </div>\n  </div>\n</div>\n\n<!--  NEXT CHRONICLES  -->\n<div class=\"next-chronicles\">\n  <div class=\"section-label\">Next Chronicles</div>\n  <div class=\"posts-grid\">\n\n    <div class=\"post-card\">\n      <div class=\"post-region\"><a href=\"/4-days-in-bologna-the-fat-city%27s-table/\" rel=\"history\">Europe · Italy</a></div>\n      <div class=\"post-title\">Bologna: The Fat City’s Table</div>\n      <div class=\"post-excerpt\">Four days among the arcades, the ragù, and the oldest university in the world — a deep account of Emilia-Romagna's greatest city.</div>\n      <div class=\"post-meta\">\n        <span>Italy</span>\n        <span class=\"dot\"></span>\n        <span>City Guide</span>\n      </div>\n    </div>\n\n    <div class=\"post-card\">\n      <div class=\"post-region\"><a href=\"/coming-soon/\" rel=\"history\">Europe · Italy</a></div>\n      <div class=\"post-title\">The Road from Bologna to Rome</div>\n      <div class=\"post-excerpt\">Steel serpents and eternal arrivals — a chronicle of the journey south from Emilia-Romagna to the capital of the ancient world.</div>\n      <div class=\"post-meta\">\n        <span>Italy</span>\n        <span class=\"dot\"></span>\n        <span>Journey</span>\n      </div>\n    </div>\n\n    <div class=\"post-card\">\n      <div class=\"post-region\"><a href=\"/coming-soon/\" rel=\"history\">Europe · Italy</a></div>\n      <div class=\"post-title\">Rimini and the Adriatic Shore</div>\n      <div class=\"post-excerpt\">The beach city at the edge of Emilia-Romagna — more than a transit stop, if you know where to look.</div>\n      <div class=\"post-meta\">\n        <span>Italy</span>\n        <span class=\"dot\"></span>\n        <span>Day Trip Base</span>\n      </div>\n    </div>\n\n  </div>\n</div></bodycopy></div></div></div></div>";
