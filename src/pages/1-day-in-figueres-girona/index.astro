import BaseLayout from "../../layouts/BaseLayout.astro";

const pageContent = "<div id=\"T4281391803\" page-url=\"menu_web\" class=\"page pinned pinned-top fixed\"><a id=\"menu_web\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><header class=\"header-web\" role=\"banner\">\n  <br>\n  <div class=\"header-web__inner\">\n    <a class=\"header-web__brand\" href=\"/\">THERE &amp; BACK AGAIN</a>\n\n    <nav aria-label=\"Primary\" class=\"header-web__nav\">\n      <a class=\"header-web__link\" href=\"/chronicles/\">CHRONICLES</a>\n      <a class=\"header-web__link\" href=\"/by-region/\">BY REGION</a>\n      <a class=\"header-web__link\" href=\"/about-the-traveller/\">THE TRAVELLER</a>\n    </nav>\n  </div>\n  <br>\n</header>\n\n<hr class=\"header-rule\"></bodycopy></div></div></div><div style=\"margin-top: 0px; margin-bottom: 0px;\" class=\"pages\"><div id=\"P2180337674\" page-url=\"1-day-in-figueres-girona\" class=\"page\"><a id=\"1-day-in-figueres-girona\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><!--  POST HERO  -->\n<section class=\"post-hero\">\n  <div class=\"post-route-strip\">\n    <span>Europe</span>&nbsp;· Spain · Catalonia ·&nbsp;<span>Summer 2024</span>\n  </div>\n\n  <h1 class=\"post-hero-title\"><em>1 Day in Figueres &amp; Girona:</em><br>\nA Day Inside Dalí's Mind</h1>\n  <p class=\"post-hero-sub\">One day north from Barcelona — the surrealist's own museum-tomb in Figueres, then the stacked medieval old town of Girona on its painted river. The dream and the record, in that order.</p>\n  <div class=\"post-stats\">\n    <div class=\"stat\"><span class=\"stat-num\">1</span><span class=\"stat-label\">Day</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">2</span><span class=\"stat-label\">Towns</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">22.98m</span><span class=\"stat-label\">Widest Nave</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">~A$139</span><span class=\"stat-label\">Guided Tour</span></div>\n  </div>\n</section>\n\n<!--  OPENING: THE ARRIVAL  -->\n<section class=\"opening-prose\">\n  <div class=\"narrative\">\n    <div class=\"prose\">\n      <p class=\"drop-cap\">There are museums a city builds to hold an artist, and then there is the one an artist built to hold himself. Two hours north of Barcelona, in the flat, light-struck farmland of the Empordà where the Pyrenees come down to meet the sea, Salvador Dalí spent the last decade of his life turning the burnt-out shell of his home town's theatre into a single enormous artwork — a museum that is not a building full of Dalís so much as one continuous Dalí the visitor walks around inside. He is buried beneath its stage. The traveller who comes up from Barcelona for the day is not visiting a collection. They are walking through the inside of a dead man's head, by his own design and on his own terms.</p>\n      <p>The day pairs that with its opposite. An hour back down the line sits <strong>Girona</strong>, a city that did not dream itself into being but accumulated, slowly, across two thousand years — Roman wall on Carolingian wall, a Jewish quarter folded into the dark, a cathedral with the widest Gothic nave in the world, all of it stacked up a hillside above a river hung with painted houses. Where Figueres is one man's imagination poured into concrete, Girona is the patient opposite: real centuries, real lives, layered into stone until the city became a thing no single mind could have planned.</p>\n      <p>Two registers of Catalonia in one day. The dream and the record. The traveller takes them in that order, and the order matters.</p>\n    </div>\n  </div>\n</section>\n\n<!--  CHAPTER I  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter I</div>\n    <h2 class=\"chapter-name\"><em>The</em> Egg-Crowned Theatre</h2>\n    <p class=\"chapter-epithet\">Figueres — the Teatre-Museu Dalí, the largest surrealist object on earth</p>\n\n    <div class=\"prose\">\n      <p>The building announces itself before any of its contents do: a dusty-red tower-block of a thing, its parapet lined with rows of enormous white eggs and studded all over with golden bread-rolls, topped by a vast geodesic dome of glass that catches the Empordà light like a faceted soap-bubble. This was the <strong>Teatre Municipal de Figueres</strong>, where a teenage Dalí held his first public exhibition, and which burned in the last days of the Spanish Civil War. Dalí spent his final years rebuilding it not as a theatre but as a tomb and a manifesto — opened in 1974, and meant from the start to be experienced as a single coherent object rather than a set of rooms. “I want my museum to be a single block, a labyrinth,” he said, “a great surrealist object.” It is exactly that.</p>\n      <p>Inside, nothing behaves. A black 1941 Cadillac sits in the central courtyard with rain falling <em>inside</em> the car onto mannequins and snails — the <strong>Taxi Plujós</strong>, the Rainy Taxi — beneath a tower of stacked tyres crowned by a fishing boat that drips blue beads. Upstairs, a room resolves, from one precise spot through a lens, into the face of Mae West: a sofa for lips, a fireplace for a nose, two framed landscapes for eyes — the <strong>Sala Mae West</strong>, a face you have to stand in exactly the right place to see, which is the whole museum's logic in miniature. There is the great trompe-l'oeil canvas that, viewed from across the room, dissolves the nude figure of Gala at a window into the brooding portrait of Abraham Lincoln. There is the ceiling of the <strong>Palau del Vent</strong>, where Dalí and Gala float upward seen from below, the soles of their giant feet looming over the visitor. And there is, beneath the stage where the old theatre's audience once sat, the plain crypt with the single flat stone: <em>Salvador Dalí, 1904–1989</em>. He arranged to be buried inside his own masterpiece. People walk over his grave by the thousand without always realising it.</p>\n      <p>What the museum refuses to be is restful or explained. There are no long wall-texts, no chronology, no attempt to teach. Dalí built a machine for disorientation and put himself at the centre of it, and the only honest way to take it is to surrender to the spectacle and stop demanding that it make sense. An hour and a half is enough to feel thoroughly worked over by it; much longer and the relentlessness begins to tire. Then back out into the ordinary sunlight of a modest Catalan market town that happens to contain the strangest building in Spain.</p>\n    </div>\n  </div>\n\n  <aside class=\"pull\">\n    <p>Dalí built a machine for disorientation and put himself at the centre of it — then arranged to be buried beneath the stage.</p>\n  </aside>\n</section>\n\n<!--  CHAPTER II  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter II</div>\n    <h2 class=\"chapter-name\"><em>The</em> City on the Onyar</h2>\n    <p class=\"chapter-epithet\">Girona — the painted river, the widest Gothic nave, and the quarter folded into the dark</p>\n\n    <div class=\"prose\">\n      <p>Girona is the counterweight, and after the engineered delirium of Figueres it lands like cool water. The first sight is the <strong>Cases de l'Onyar</strong> — the tall, narrow houses jammed shoulder to shoulder along the river, their faces washed in ochre and rust and faded gold, doubled in the slow green water below. From the <strong>Pont de les Peixateries Velles</strong>, the red iron footbridge built by Gustave Eiffel's workshop a dozen years before the tower in Paris, the whole stacked old town rises behind them up the hill, and the city's entire two-thousand-year argument is visible at once: layer on layer, nothing thrown away.</p>\n      <p>Climbing into it, the lanes narrow and darken into <strong>El Call</strong>, one of the best-preserved medieval Jewish quarters in Europe — stepped alleys barely a shoulder wide, stone passages that duck under buildings and emerge into sudden small courtyards, a place that held a thriving Jewish community for six centuries until the expulsion of 1492 and then simply sealed shut, preserving itself by being forgotten. Above it all the <strong>Catedral de Santa Maria</strong> crowns the hill behind a theatrical Baroque staircase of ninety steps, and inside holds its quiet world record: a single Gothic nave <strong>22.98 metres wide</strong>, the widest in the world, a single vast unbroken vault of stone that the medieval builders gambled everything on and won. Television hunted this scenery down — the cathedral steps stood in for the Great Sept of Baelor, the Call for the alleys of Braavos — but the city wore its strangeness long before any camera found it. Walk the <strong>Passeig de la Muralla</strong>, the rampart path along the old Carolingian and medieval walls, for the long view back over the rooftops to the Pyrenees, and drop into the twelfth-century <strong>Banys Àrabs</strong> for the cool, domed quiet of a Romanesque bathhouse built in the Moorish manner.</p>\n      <p>Where Dalí's museum is a single mind turned inside out, Girona is the accumulation of thousands — Roman engineers, Jewish scholars, medieval masons, Catalan merchants — none of them planning the whole, all of them adding to it. The traveller who has just spent the morning inside one man's dream feels the difference physically: this is what time builds when no one is performing.</p>\n    </div>\n  </div>\n</section>\n\n<!--  CHAPTER III  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter III</div>\n    <h2 class=\"chapter-name\"><em>The</em> Day, Solved</h2>\n    <p class=\"chapter-epithet\">Getting the two towns into one day without losing either</p>\n\n    <div class=\"prose\">\n      <p>The geography is generous and the trap is real. Figueres, Girona and Barcelona sit on the same north–south line, so the day is a simple out-and-back — but the Dalí museum is the thing that fills up, and the order is what saves the day. <strong>Figueres first</strong>, ideally not long after opening, before the coach tours from the coast arrive and the labyrinth turns into a queue; then south to <strong>Girona</strong> for the afternoon, when a medieval old town is at its best in the long Mediterranean light; then back to Barcelona for dinner. Done backwards, the day spends its freshest hours in a museum carpark and arrives in Girona tired.</p>\n      <p>This is precisely the kind of day where a <strong>guided tour earns its fare</strong>, and the trip took one: a single coach run from Barcelona that handled the driving, the timed museum entry and the order in one solved problem, leaving early (around 07:50) and back in the city by evening. The independent version works just as well for the confident — Catalonia's high-speed trains make Figueres and Girona genuinely easy — but it means buying the Dalí ticket online in advance and watching the connections. Either way the day ends back in Barcelona, and on this trip it ended well: a table at <strong>Eldiset</strong> in El Born, Catalan small plates and a long pour of wine, the surrealist's eggs and the painted river both receding into the evening.</p>\n    </div>\n  </div>\n</section>\n\n<div class=\"ornament\">· · · ✦ · · ·</div>\n\n<div class=\"beat\">The curated dream and the uncurated record, on the same line, in a single day.</div>\n\n<!--  PRACTICAL: GETTING THERE  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Getting There &amp; Around</div>\n    <div class=\"prac-dates\">From Barcelona · Summer 2024</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">From Barcelona</div>\n    <div class=\"prac-item\">Figueres and Girona sit on the same line north toward France. High-speed <strong>AVE/Avant trains</strong> from Barcelona Sants reach <strong>Figueres-Vilafant</strong> in about 55 minutes and <strong>Girona</strong> in about 40; slower regional trains are cheaper and take longer.</div>\n    <div class=\"prac-item\">Frequent trains link <strong>Figueres and Girona</strong> in roughly 30–40 minutes — what makes the pairing a single clean day.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">The Easy Option</div>\n    <div class=\"prac-item\">The trip took a <strong>guided day tour</strong> from Barcelona (around <strong>A$139</strong>), bundling transport, timed Dalí entry and the Figueres-then-Girona order. Departs early (~07:50), back by evening.</div>\n  </div>\n</section>\n\n<!--  PRACTICAL: TICKETS  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">The Two Towns — Tickets &amp; Hours</div>\n    <div class=\"prac-dates\">Costs in AUD (€ noted)</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Figueres</div>\n    <div class=\"prac-item\"><strong>Teatre-Museu Dalí</strong> — from around <strong>A$31 (€18.50 online, €20.50 at the door)</strong>; includes the adjoining <strong>Dalí·Joies</strong> (Jewels) room. Open roughly <strong>09:30–18:00</strong> (winter from 10:30; daily <strong>09:00–20:00</strong> in July–August); <strong>closed Mondays</strong> except July–August. Buy online with a time slot — it sells out.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Girona</div>\n    <div class=\"prac-item\"><strong>Girona Cathedral</strong> — around <strong>A$12 (€7)</strong>, including the cloister and the Tapestry of Creation.</div>\n    <div class=\"prac-item\"><strong>Banys Àrabs</strong> (Arab Baths) and the <strong>Museum of Jewish History</strong> in El Call — a few euros each.</div>\n    <div class=\"prac-item\"><strong>Passeig de la Muralla &amp; the Onyar houses</strong> — free. The best of Girona costs nothing.</div>\n  </div>\n</section>\n\n<!--  PRACTICAL: ON THE DAY  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">On the Day</div>\n    <div class=\"prac-dates\">Order, viewpoints, walls</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Don't Miss</div>\n    <div class=\"prac-item\"><strong>Figueres in the morning, Girona in the afternoon.</strong> The single rule that makes the day work.</div>\n    <div class=\"prac-item\"><strong>Stand on the marks.</strong> The Mae West room and the Lincoln canvas only resolve from one exact spot — find the viewpoint, don't just walk past.</div>\n    <div class=\"prac-item\"><strong>Climb the cathedral steps, then walk the walls.</strong> The Passeig de la Muralla gives the long view back over the rooftops to the mountains.</div>\n  </div>\n</section>\n\n<!--  PRACTICAL: TIPS & WATCH-OUTS  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Tips &amp; Watch-outs</div>\n    <div class=\"prac-dates\">The rules that save the day</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Get It Right</div>\n    <div class=\"tip-row\"><strong>Book the Dalí ticket online, with a time slot.</strong> It is the one thing that sells out, and the museum is the reason for the day.</div>\n    <div class=\"tip-row\"><strong>The museum is overwhelming on purpose.</strong> Ninety minutes is plenty; don't plan to “do it thoroughly.” Surrender to it instead.</div>\n    <div class=\"tip-row\"><strong>Mondays are risky.</strong> The Dalí museum closes Mondays for much of the year — check before building the day around it.</div>\n    <div class=\"tip-row\"><strong>Don't add a third town.</strong> Figueres + Girona is a full day. Cadaqués, Dalí's coastal home, is wonderful but belongs to its own trip.</div>\n    <div class=\"tip-row\"><strong>Take the tour if you'd rather not watch connections</strong> — bundling the entry and the order is money well spent on this day.</div>\n  </div>\n</section>\n\n<!--  VIATOR TOURS  -->\n<div class=\"tours\">\n  <div class=\"tours-label\">Guided Experiences — Figueres &amp; Girona</div>\n  <div class=\"tours-grid\">\n    <a class=\"tour-card\" href=\"https://www.viator.com/tours/Barcelona/Girona-and-Figueres-tour-with-Dali-Museum/d562-9866P30?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n      <div class=\"tour-type\">Small Group</div>\n      <div class=\"tour-name\">Girona, Figueres &amp; Dalí Museum</div>\n      <div class=\"tour-meta\">Girona's old town and the Dalí Theatre-Museum in a small group — the classic pairing, transport and order handled.</div>\n      <div class=\"tour-footer\">\n        <span class=\"tour-price\">Day trip from Barcelona</span>\n        <span class=\"tour-link-label\">View on Viator →</span>\n      </div>\n    </a>\n    <a class=\"tour-card\" href=\"https://www.viator.com/tours/Barcelona/Girona-Figueres-and-Dali-Museum-Day-Trip-from-Barcelona/d562-2140JTEBA09?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n      <div class=\"tour-type\">Full Day</div>\n      <div class=\"tour-name\">Girona, Figueres &amp; Dalí Museum — Full-Day Tour</div>\n      <div class=\"tour-meta\">The full-day coach trip the day was built on — the museum's timed entry and the two-town order solved in one.</div>\n      <div class=\"tour-footer\">\n        <span class=\"tour-price\">Full-day from Barcelona</span>\n        <span class=\"tour-link-label\">View on Viator →</span>\n      </div>\n    </a>\n    <a class=\"tour-card\" href=\"https://www.viator.com/tours/Barcelona/Full-Day-Tour-To-Girona-Figueres-and-Cadaques-from-Barcelona/d562-6877P93?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n      <div class=\"tour-type\">+ Cadaqués</div>\n      <div class=\"tour-name\">Girona, Dalí Museum &amp; Cadaqués</div>\n      <div class=\"tour-meta\">Adds Dalí's whitewashed coastal home on the Costa Brava to the museum and the medieval city.</div>\n      <div class=\"tour-footer\">\n        <span class=\"tour-price\">Full-day from Barcelona</span>\n        <span class=\"tour-link-label\">View on Viator →</span>\n      </div>\n    </a>\n  </div>\n</div>\n\n<!--  ITINERARY  -->\n<section class=\"itin-block\">\n  <div class=\"itin-inner\">\n    <div class=\"itin-block-title\">One Day from Barcelona at a Glance</div>\n\n    <p class=\"itin-meta\">Shape: <strong>a single long day north, the dream and the record</strong>.</p>\n    <p class=\"itin-meta\">Booked as: <strong>guided tour, ~A$139 per person</strong>.</p>\n\n    <div class=\"itin-section-head\">Figueres &amp; Girona — day trip</div>\n    <div class=\"itin-days\">\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">~07:50</span>Depart Barcelona, north into the Empordà.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Morning</span><strong>Teatre-Museu Dalí</strong>, Figueres: the egg-crowned theatre, the Rainy Taxi, the Mae West room, the crypt beneath the stage.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Midday</span>South to <strong>Girona</strong>.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">PM</span>The <strong>Cases de l'Onyar</strong> and the Eiffel bridge; <strong>El Call</strong>; the <strong>cathedral</strong> and its ninety steps; the walls along the <strong>Passeig de la Muralla</strong>.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Eve</span>Back to Barcelona. Dinner at <strong>Eldiset</strong> in El Born.</div>\n    </div>\n  </div>\n</section>\n\n<!--  CLOSING REFLECTION  -->\n<section class=\"post-closing\">\n  <div class=\"narrative\">\n    <div class=\"prose\">\n      <p>The line runs south into the dusk, the Empordà flattening out behind, and the day resolves into its two halves the way the Lincoln canvas resolves from across a room. Figueres was a single will made visible — a man who decided his own museum should be his final and largest work, who built a labyrinth of his own obsessions and then lay down beneath its stage so that visitors would walk over him forever. Girona was the opposite lesson: a city no one designed, made beautiful by sheer accumulation, two thousand years of people adding stone to stone with no master plan and no signature at the bottom.</p>\n      <p>The traveller carries both south. There is something clarifying in seeing them on the same day — the curated dream and the uncurated record, the artist who controlled every angle and the city that controls nothing and is lovelier for it. Barcelona waits at the end of the line with the lights coming on and a table held in El Born, and the question the day leaves, quietly, is which of the two will last longer: the man who built himself a monument, or the city that never tried.</p>\n    </div>\n  </div>\n</section>\n\n<div class=\"beat\">But the road is ever onward.</div>\n\n<!--  FAQ  -->\n<section class=\"faq-block\">\n  <div class=\"faq-inner\">\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Is the Dalí Museum in Figueres worth a day trip from Barcelona?</div>\n      <div class=\"faq-a\">Yes — it is one of the most singular museums in the world, designed by Dalí himself as a single immersive artwork rather than a conventional gallery, and it holds his tomb beneath the stage. Paired with the medieval city of Girona an hour away, it makes a full, varied day. Figueres is about two hours from Barcelona by road, or under an hour by high-speed train.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">How do you get from Barcelona to Figueres and Girona?</div>\n      <div class=\"faq-a\">All three sit on the same north line. High-speed AVE/Avant trains from Barcelona Sants reach Figueres-Vilafant in about 55 minutes and Girona in about 40, and trains link Figueres and Girona in 30–40 minutes. Many visitors take a guided day tour from Barcelona that handles the transport and the museum timing in one.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Do you need to book Dalí Museum tickets in advance?</div>\n      <div class=\"faq-a\">Yes, in summer especially. The Teatre-Museu Dalí uses timed entry and sells out, sometimes days ahead. Buy online with a time slot, or take a tour that includes skip-the-line entry. Note that the museum closes on Mondays for much of the year.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Can you visit both Figueres and Girona in one day?</div>\n      <div class=\"faq-a\">Comfortably — they're 30–40 minutes apart on the same rail line. The trick is order: do Figueres and the Dalí museum first thing in the morning, before the crowds, then spend the afternoon in Girona's old town, then return to Barcelona for the evening.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">What is there to see in Girona besides the cathedral?</div>\n      <div class=\"faq-a\">The painted Onyar riverhouses and the Eiffel footbridge, El Call (one of Europe's best-preserved medieval Jewish quarters), the Passeig de la Muralla walk along the old city walls, and the twelfth-century Arab Baths. The cathedral itself holds the widest Gothic nave in the world. Fans of Game of Thrones will recognise the cathedral steps and the Call.</div>\n    </div>\n  </div>\n</section>\n\n\n\n<!--  FURTHER READING  -->\n<section class=\"next-chronicles\">\n  <div class=\"narrative\">\n    <h2 class=\"chapter-name\" style=\"text-align:center; margin-bottom: 2.5rem;\"><em>Further</em> Reading</h2>\n    <div class=\"posts-grid\">\n      <a class=\"post-card\" href=\"/7-days-in-barcelona/\">\n        <div class=\"post-region\">Spain · Catalonia</div>\n        <div class=\"post-title\">Barcelona: Gaudí's Unfinished Argument</div>\n        <div class=\"post-excerpt\">The base city this day departs from — Gaudí, the Gothic Quarter, and a city that never stops building.</div>\n      <div class=\"post-meta\">7 days&nbsp;<span class=\"dot\"></span>&nbsp;City Guide</div>\n      </a>\n      <a class=\"post-card\" href=\"/1-day-in-tarragona-sitges/\">\n        <div class=\"post-region\">Spain · Catalonia</div>\n        <div class=\"post-title\">Tarragona &amp; Sitges: Roman Stone and Seaside Light</div>\n        <div class=\"post-excerpt\">The other long day trip from Barcelona — a Roman amphitheatre on the sea, and a white town by the water.</div>\n      <div class=\"post-meta\">1 day&nbsp;<span class=\"dot\"></span>&nbsp;Day Trip</div>\n      </a>\n      <a class=\"post-card\" href=\"/4-weeks-portugal-to-spain-by-rail-road/\">\n        <div class=\"post-region\">Iberia · Circuit</div>\n        <div class=\"post-title\">Portugal to Spain by Rail and Road</div>\n        <div class=\"post-excerpt\">The full thirty-day circuit — Porto to Barcelona, almost entirely overland, with the costs laid bare.</div>\n      <div class=\"post-meta\">4 weeks&nbsp;<span class=\"dot\"></span>&nbsp;Chronicle</div>\n      </a>\n    </div>\n  </div>\n</section></bodycopy></div></div></div></div>";
