import BaseLayout from "../../layouts/BaseLayout.astro";

const pageContent = "<div id=\"T4281391803\" page-url=\"menu_web\" class=\"page pinned pinned-top fixed\"><a id=\"menu_web\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><header class=\"header-web\" role=\"banner\">\n  <br>\n  <div class=\"header-web__inner\">\n    <a class=\"header-web__brand\" href=\"#\" rel=\"home-page\">THERE &amp; BACK AGAIN</a>\n\n    <nav aria-label=\"Primary\" class=\"header-web__nav\">\n      <a class=\"header-web__link\" href=\"/chronicles/\" rel=\"history\">CHRONICLES</a>\n      <a class=\"header-web__link\" href=\"/by-region/\" rel=\"history\">BY REGION</a>\n      <a class=\"header-web__link\" href=\"/about-the-traveller/\" rel=\"history\">THE TRAVELLER</a>\n    </nav>\n  </div>\n  <br>\n</header>\n\n<hr class=\"header-rule\"></bodycopy></div></div></div><div style=\"margin-top: 0px; margin-bottom: 0px;\" class=\"pages\"><div id=\"N3845871759\" page-url=\"5-days-in-porto-the-city-the-river-built\" class=\"page\"><a id=\"5-days-in-porto-the-city-the-river-built\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><!--  POST HERO  -->\n<section class=\"post-hero\">\n  <div class=\"post-route-strip\">\n    <span>Europe</span>&nbsp;· Portugal · Douro ·&nbsp;<span>Summer 2024</span>\n  </div>\n\n  <h1 class=\"post-hero-title\"><em>5 Days in Port:</em><br>\nThe City the River Built</h1>\n  <p class=\"post-hero-sub\">Five days in the city that turned a river into an industry — granite and gold, the climb up from Ribeira, port across the water, and a sunset for every evening.</p>\n  <div class=\"post-stats\">\n    <div class=\"stat\"><span class=\"stat-num\">5</span><span class=\"stat-label\">Days</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">6</span><span class=\"stat-label\">Bridges</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">2</span><span class=\"stat-label\">Day Trips</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">~A$637</span><span class=\"stat-label\">7-Night Stay</span></div>\n  </div>\n</section>\n\n<!--  OPENING: THE ARRIVAL  -->\n<section class=\"opening-prose\">\n  <div class=\"narrative\">\n    <div class=\"prose\">\n      <p class=\"drop-cap\">The city reads downhill. Step out of São Bento into the noise of the Baixa and everything — the cobbles, the trams, the gulls, the smell of grilling sardines and the colder smell of the water underneath it — slopes away from you toward the Douro, and the river is the thing the whole place is arranged around. Porto does not sit beside its river the way Lisbon sits above its estuary, at a polite distance. Porto leans into the Douro, tips its houses down the gorge toward it, stacks them in pastel tiers on both banks until the last row has its feet in the working quay. The river made the city. It floated the wine down from the terraces upstream, carried the barrels to the lodges, paid for the gold inside the churches and the granite of the bridges, and then sat at the bottom of every view as the reward for the climb.</p>\n      <p>Because there is always a climb. The traveller learns this on the first evening, hauling a bag up from Ribeira to a room in the old town, lungs working, and learns it again every day after — that Porto charges a tax in altitude on everything worth seeing, and pays it back in the view from the top. Five days in the city, plus two long days out to Galicia and the Douro vineyards, and the shape of it never changes: up through granite and azulejo, down to the water, across to the port, and a sunset somewhere high to close the account.</p>\n      <p>The pilgrim earns Santiago. In Porto, the traveller earns the river, one staircase at a time.</p>\n    </div>\n  </div>\n</section>\n\n<!--  CHAPTER I  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter I</div>\n    <h2 class=\"chapter-name\"><em>The</em> Climb</h2>\n    <p class=\"chapter-epithet\">The upper town — Clérigos, Lello, and the tiled vertical city</p>\n\n    <div class=\"prose\">\n      <p>Porto is a vertical argument. The old town climbs from the quay in a tangle of lanes that were never planned so much as worn, and the monuments stand at the top of them like prizes. The <strong>Torre dos Clérigos</strong> is the plainest statement of the city's logic: Nicolau Nasoni's baroque bell tower, seventy-six metres of granite, two hundred and forty steps, built in the eighteenth century as the tallest thing in Portugal and used for two centuries as the landmark ships steered by coming up the river. The traveller climbs it for the same reason the sailors trusted it — from the top the whole city resolves at once, the red roofs and the bridges and the silver bend of the Douro, and the geography that felt like punishment at street level suddenly makes sense.</p>\n      <p>Down the hill is the <strong>Livraria Lello</strong>, the 1906 bookshop that the queue outside has turned into a chore and the inside still, somehow, redeems: the crimson staircase that splits and rejoins under a stained-glass ceiling, the wooden shelves, the rumour of Harry Potter that the shop neither confirms nor denies. The five-euro ticket comes off the price of a book, which is the honest way to treat it — buy something, and it stops being a museum of itself. A few streets east the <strong>Capela das Almas</strong> wears its sermon on the outside, sixteen thousand blue-and-white azulejo tiles wrapped around a street corner, and <strong>São Bento station</strong> does the grander version indoors — twenty thousand tiles narrating the country's battles and harvests across the concourse walls, so that the busiest room in Porto is also one of its best galleries. Between them the <strong>Mercado do Bolhão</strong> trades fish and flowers and dried cod under its iron roof, and the <strong>Avenida dos Aliados</strong> runs its beaux-arts slope up to the town hall, wide as a Parisian boulevard and twice as steep.</p>\n    </div>\n  </div>\n</section>\n\n<div class=\"beat\">Porto charges a tax in altitude on everything worth seeing, and pays it back in the view from the top.</div>\n\n<!--  CHAPTER II  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter II</div>\n    <h2 class=\"chapter-name\"><em>The</em> Gold</h2>\n    <p class=\"chapter-epithet\">The churches — São Francisco, Santa Clara, and the Arabian Room</p>\n\n    <div class=\"prose\">\n      <p>The plainest doors in Porto open onto the most extravagant rooms in Portugal. The <strong>Igreja de São Francisco</strong> keeps a sober Gothic face to the street and hides behind it the <em>Igreja do Ouro</em>, the Church of Gold: an interior where every carved vine, cherub and rose garland has been smothered in gilded woodwork, and the Tree of Jesse climbs one wall tracing Christ's lineage in glittering branches. The figure is half a tonne of gold leaf, give or take, and the effect is not beauty so much as vertigo — a forest of money grown indoors. Up the hill the <strong>Igreja de Santa Clara</strong> does the same trick in a quieter setting, the <em>talha dourada</em> packed so densely it reads, at first, as a single golden surface until the eye picks out the saints and angels buried in it.</p>\n      <p>Not all the wealth is sacred. The <strong>Palácio da Bolsa</strong>, the old stock exchange, built its argument for commerce in stone: a glass-domed Hall of Nations ringed with the coats of arms of every country Porto traded with, and, deeper in, the <strong>Arabian Room</strong> — a Moorish-revival fantasy modelled on the Alhambra, twenty years in the making, its every surface gilded and inscribed, a merchant city's idea of magnificence. The <strong>Sé</strong>, the fortress cathedral up on its rock where Henry the Navigator was baptised, is the oldest note in the chord and the most austere, its azulejo cloister the one indulgence it allows itself. Together they are the spent form of the river's wealth — the port money turned to gold and stone and held up to the light.</p>\n    </div>\n  </div>\n</section>\n\n<!--  CHAPTER III  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter III</div>\n    <h2 class=\"chapter-name\"><em>Down to</em> the Water</h2>\n    <p class=\"chapter-epithet\">Ribeira, the bridge, and the crossing to Gaia</p>\n\n    <div class=\"prose\">\n      <p>Everything in Porto eventually falls to the Ribeira. The lanes of the old town pour down through arches and washing lines to the quay, where the pastel houses lean over the water in their picturesque dilapidation and the cafés put their tables out along the river wall. It is the most photographed corner of the city and, by evening, the most crowded, and it is still worth the descent — to stand on the quay among the <em>rabelo</em> boats that once carried the wine, with the <strong>Ponte Dom Luís I</strong> arched overhead and the lodges glowing across the water, is to see the whole machine of the city laid out at once.</p>\n      <p>The bridge is the city's signature: Téophile Seyrig's double-deck iron arch from 1886, designed by a partner of Eiffel's and, briefly, the longest of its kind in the world. The traveller crosses on the upper deck, on foot, beside the metro, with the river dropping away forty metres below and the whole of Porto and Gaia spread on either side — one of the great free walks in Europe. On the far bank a short steep climb leads to the <strong>Mosteiro da Serra do Pilar</strong>, its round church and circular cloister unique in Portugal, and to the miradouro beside it, which holds the postcard view: the bridge, the river, the stacked city, all of it at once. The funicular dos Guindais will spare the legs one of the climbs back, for a couple of euros; the traveller takes it once and walks the rest, because Porto is best understood as a thing earned on foot.</p>\n    </div>\n  </div>\n\n  <aside class=\"pull\">\n    <p>The river made the city, and then sat at the bottom of every view as the reward for the climb.</p>\n  </aside>\n</section>\n\n<!--  CHAPTER IV  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter IV</div>\n    <h2 class=\"chapter-name\"><em>The</em> Lodges</h2>\n    <p class=\"chapter-epithet\">Vila Nova de Gaia — port, the cellars, and the long evening light</p>\n\n    <div class=\"prose\">\n      <p>The wine that named the city is not made in it. Across the river in <strong>Vila Nova de Gaia</strong> the port lodges line the south bank, their names painted in white on the dark roofs — Cálem, Taylor's, Graham's, Sandeman — and inside them the fortified wine sleeps in cool barrel halls smelling of oak and dark fruit, brought down from the Douro terraces to age in the river's even temperature. <strong>Caves Cálem</strong>, the nearest to the bridge, runs the easy version: a walk through the cellars, the story of the demarcated region, and a tasting of a white and a ruby at the end, with a fado show some evenings for the price of lingering. <strong>Taylor's</strong>, founded in 1692 and still independent, sits higher up the hill and pours its Chip Dry white and an LBV on a terrace that holds the best long view back across the water to the city.</p>\n      <p>And the city, from here, in the last hour of light, is the reason to have crossed. The traveller takes a glass out onto the terrace or up to the <strong>Esplanada do Teleférico</strong>, and Porto stacks itself gold and pink across the gorge, the Dom Luís bridge a black filigree against it, the river going molten below. Every evening in Porto ends like this somewhere — at the <strong>Miradouro da Vitória</strong> over the old town, in the gardens of the <strong>Palácio de Cristal</strong> with the peacocks, here on the Gaia bank with the port in hand. The sunset is not a bonus. In a city built on a gorge, it is the daily dividend the climb pays out.</p>\n    </div>\n  </div>\n</section>\n\n<div class=\"ornament\">· · · ✦ · · ·</div>\n\n<div class=\"beat\">Up through granite and azulejo, down to the water, across to the port, and a sunset somewhere high to close the account.</div>\n\n<!--  PRACTICAL: GETTING THERE & AROUND  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Getting There &amp; Around</div>\n    <div class=\"prac-dates\">Porto · Summer 2024</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">From the Airport</div>\n    <div class=\"prac-item\">Francisco Sá Carneiro is on the <strong>Metro purple line (Line E)</strong>, about 30 minutes to the centre for a single Andante ticket plus the card. A taxi or Bolt to Ribeira runs roughly <strong>A$30–40</strong>.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Getting Around</div>\n    <div class=\"prac-item\"><strong>On foot, mostly</strong> — the historic core is small and walkable, but <em>steep</em>. Comfortable shoes are not optional.</div>\n    <div class=\"prac-item\">The <strong>Funicular dos Guindais</strong> links the Ribeira quay to the upper town near Batalha for about <strong>A$4 (€2.50)</strong> — one of the gentler ways back up the hill.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Where to Base</div>\n    <div class=\"prac-item\">The trip's Airbnb sat on <strong>Rua de Trás</strong>, in the old town between the Sé and Ribeira: in the thick of it, a hard climb home, worth it. Roughly <strong>A$637 for the seven-night stay</strong>.</div>\n  </div>\n</section>\n\n<!--  PRACTICAL: SITES & TICKETS  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Sites &amp; Tickets</div>\n    <div class=\"prac-dates\">Costs in AUD (€ locked)</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">The Climb</div>\n    <div class=\"prac-item\"><strong>Torre dos Clérigos</strong> (tower + museum) — about <strong>A$13 (€8)</strong>. The climb is tight; go early.</div>\n    <div class=\"prac-item\"><strong>Livraria Lello</strong> — about <strong>A$8 (€5)</strong>, redeemable against a book.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">The Gold</div>\n    <div class=\"prac-item\"><strong>Igreja de São Francisco</strong> (Church of Gold, incl. museum) — about <strong>A$15 (€9)</strong>. No photography inside.</div>\n    <div class=\"prac-item\"><strong>Palácio da Bolsa</strong> — about <strong>A$20 (€12)</strong>, guided visit only; book the Arabian Room slot ahead in summer.</div>\n    <div class=\"prac-item\"><strong>Sé do Porto</strong> — church free; the azulejo <strong>cloister about A$5 (€3)</strong>.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">The River &amp; Gaia</div>\n    <div class=\"prac-item\"><strong>Mosteiro da Serra do Pilar</strong> — cloister and dome about <strong>A$5 (€3)</strong>; the miradouro beside it is free.</div>\n    <div class=\"prac-item\"><strong>Port lodge tours</strong> (Cálem, Taylor's) — roughly <strong>A$10–25</strong> depending on the house and the flight of tastings.</div>\n  </div>\n</section>\n\n<!--  PRACTICAL: EATING IN PORTO  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Eating in Porto</div>\n    <div class=\"prac-dates\">The trip's table</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Snacks &amp; Lunch</div>\n    <div class=\"prac-item\"><strong>Cervejaria Gazela</strong> — the tiny <em>cachorrinhos</em> (thin spiced hot-dogs, cut small and crisp). Order a plate, a beer, stand if you must.</div>\n    <div class=\"prac-item\"><strong>Confeitaria do Bolhão</strong> — a century-old pastelaria for <em>rissóis</em>, codfish cakes and a <em>pastel de nata</em>.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">The Francesinha</div>\n    <div class=\"prac-item\"><strong>O Afonso</strong> (Rua da Torrinha) and Café Santiago — Porto's monument in sandwich form: ham, sausage and steak under melted cheese and a beer-and-tomato sauce, an egg on top.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Dinner</div>\n    <div class=\"prac-item\"><strong>Rogério do Redondo</strong> (homely) and <strong>DOP</strong> — chef Rui Paula, Largo de São Domingos (fine). Book DOP ahead.</div>\n    <div class=\"prac-item\"><strong>To drink</strong> — a white port and tonic before dinner; <em>vinho verde</em> with the fish.</div>\n  </div>\n</section>\n\n<!--  PRACTICAL: TIPS & WATCH-OUTS  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Tips &amp; Watch-outs</div>\n    <div class=\"prac-dates\">For the days in the city</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">On the Ground</div>\n    <div class=\"tip-row\"><strong>The city is vertical.</strong> Plan the day downhill where you can; save the funicular and the metro for the climbs back.</div>\n    <div class=\"tip-row\"><strong>Lello and Clérigos sell timed tickets online</strong> — buy ahead in summer or lose an hour to the queue.</div>\n    <div class=\"tip-row\"><strong>Cross the Dom Luís upper deck on foot.</strong> It is free, it is the best view in the city, and it doubles as the walk to Gaia.</div>\n    <div class=\"tip-row\"><strong>Build the day trips in early.</strong> Santiago and the Douro eat a full day each — don't leave them to the end.</div>\n    <div class=\"tip-row\"><strong>Sunday mornings</strong> some churches restrict tourist visits during Mass. Check before climbing the hill to a closed door.</div>\n  </div>\n</section>\n\n<!--  VIATOR TOURS  -->\n<div class=\"tours\">\n  <div class=\"tours-label\">Guided Experiences — Porto</div>\n  <div class=\"tours-grid\">\n    <a class=\"tour-card\" href=\"https://www.viator.com/tours/Porto/Skip-the-Line-Port-Wine-Lodges-Tour-Including-7-Wine-Tastings/d26879-31913P1?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n      <div class=\"tour-type\">Port &amp; Wine</div>\n      <div class=\"tour-name\">Port Wine Lodges Tour — 7 Tastings</div>\n      <div class=\"tour-meta\">Across the river in Vila Nova de Gaia — the cellars, the families, and how to taste port like a local.</div>\n      <div class=\"tour-footer\">\n        <span class=\"tour-price\">From ~A$45</span>\n        <span class=\"tour-link-label\">View on Viator →</span>\n      </div>\n    </a>\n    <a class=\"tour-card\" href=\"https://www.viator.com/tours/Porto/Porto-Walking-Tour/d26879-5902PORTOWALK?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n      <div class=\"tour-type\">Walking Tour</div>\n      <div class=\"tour-name\">Best of Porto Small-Group Walking Tour</div>\n      <div class=\"tour-meta\">The vertical old town read by a local guide — Clérigos, the Sé, São Bento and the lanes down to Ribeira.</div>\n      <div class=\"tour-footer\">\n        <span class=\"tour-price\">From ~A$30</span>\n        <span class=\"tour-link-label\">View on Viator →</span>\n      </div>\n    </a>\n    <a class=\"tour-card\" href=\"https://www.viator.com/tours/Porto/Porto-Food-and-Wine-Tasting-Tour/d26879-5902FOODWINE?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n      <div class=\"tour-type\">Food Tour</div>\n      <div class=\"tour-name\">Porto Food &amp; Wine Tasting Tour</div>\n      <div class=\"tour-meta\">Francesinha, codfish, <em>vinho verde</em> and port — northern Portuguese cooking found without the trial and error.</div>\n      <div class=\"tour-footer\">\n        <span class=\"tour-price\">From ~A$130</span>\n        <span class=\"tour-link-label\">View on Viator →</span>\n      </div>\n    </a>\n  </div>\n</div>\n\n<!--  ITINERARY  -->\n<section class=\"itin-block\">\n  <div class=\"itin-inner\">\n    <div class=\"itin-block-title\">Five Days in Porto at a Glance</div>\n\n    <p class=\"itin-meta\">Shape: <strong>a base city on a gorge — the old town and the river, with two day trips folded in</strong>.</p>\n    <p class=\"itin-meta\">Stay: <strong>Rua de Trás, old town, ~A$637 / 7 nights</strong>.</p>\n\n    <div class=\"itin-section-head\">Porto — the city and its day trips</div>\n    <div class=\"itin-days\">\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 1</span>Arrive. Dinner by the Guindais steps (Guindalense), the lanes after dark.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 2</span>Upper town: Capela das Almas, Clérigos tower, Soares dos Reis, lunch at Confeitaria do Bolhão, São Francisco, the Bolsa, Aliados, sunset at Miradouro da Vitória.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 3</span>Day trip: <strong>Santiago de Compostela</strong>. Dinner back in Porto (Rogério do Redondo).</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 4</span>The river: Serra do Pilar and its miradouro, Ribeira, the Dom Luís bridge on foot, lunch at Cervejaria Gazela, the Sé, then Gaia — Cálem and Taylor's — and sunset with a glass of port.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 5</span>Day trip: <strong>the Douro Valley</strong>. Dinner at DOP.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 6</span>São Bento, the Bolsa, Casa da Música and Serralves out on Boavista, the Palácio de Cristal gardens at dusk.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 7</span>Mercado do Bolhão, Livraria Lello, then the bus or train out — east to Mondim de Basto, and on into the circuit.</div>\n    </div>\n  </div>\n</section>\n\n<!--  CLOSING REFLECTION  -->\n<section class=\"post-closing\">\n  <div class=\"narrative\">\n    <div class=\"prose\">\n      <p>What stays with the traveller about Porto is not a single monument — not the gold church or the iron bridge or the tiled station, fine as they are — but the <em>grain</em> of the place: granite and water, the smell of the river under the smell of the food, the way the whole city is built on the effort of getting from the top of it to the bottom and back. It is a working city that happened to become beautiful, and it wears the beauty the way it wears the azulejo on the station walls — as a surface over something that was always about labour, and trade, and the river that paid for all of it.</p>\n      <p>The port lodges will still be pouring across the water; the bridge will still be the best free walk in Europe; the sunset will still find the traveller somewhere high with a glass in hand. Porto gives generously, but never for free — it asks for the climb first, every time. And then, from the top, it hands over the river.</p>\n    </div>\n  </div>\n</section>\n\n<div class=\"beat\">But the road is ever onward.</div>\n\n<!--  FAQ  -->\n<section class=\"faq-block\">\n  <div class=\"faq-inner\">\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">How many days do you need in Porto?</div>\n      <div class=\"faq-a\">Three full days cover the city itself — the old town, the churches, the river and the Gaia port lodges — without rushing. Add a day each for the two great day trips, Santiago de Compostela and the Douro Valley, and five days is the comfortable shape.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Is Porto very hilly?</div>\n      <div class=\"faq-a\">Yes. The city climbs steeply from the Douro, and almost every walk involves a serious gradient. Wear good shoes, plan routes downhill where you can, and use the Funicular dos Guindais and the metro for the climbs back up.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Where do you taste port in Porto?</div>\n      <div class=\"faq-a\">Across the river in Vila Nova de Gaia, where the lodges line the south bank. Caves Cálem is the easiest from the bridge; Taylor's, founded in 1692, has the best terrace view back to the city. Tours include a cellar walk and tastings for around A$10–25.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Should you book Livraria Lello and Clérigos Tower in advance?</div>\n      <div class=\"faq-a\">In summer, yes. Both sell timed-entry tickets online, and buying ahead saves a long queue. The Lello ticket is redeemable against a book.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">What should you eat in Porto?</div>\n      <div class=\"faq-a\">The francesinha (a towering cheese-and-meat sandwich in sauce), cachorrinhos at Cervejaria Gazela, fresh fish with vinho verde, and a glass of white port and tonic before dinner. Save room for a pastel de nata.</div>\n    </div>\n  </div>\n</section>\n\n\n\n<!--  FURTHER READING  -->\n<section class=\"next-chronicles\">\n  <div class=\"narrative\">\n    <h2 class=\"chapter-name\" style=\"text-align:center; margin-bottom: 2.5rem;\"><em>Further</em> Reading</h2>\n    <div class=\"posts-grid\">\n      <a class=\"post-card\" href=\"/1-day-in-santiago-de-compostela/\" rel=\"history\">\n        <div class=\"post-region\">Spain · Galicia</div>\n        <div class=\"post-title\">Santiago de Compostela: The End of the Pilgrim Road</div>\n        <div class=\"post-excerpt\">The day trip north across the Minho — the cathedral, the square, and the end of every Camino.</div>\n      <div class=\"post-meta\">1 day&nbsp;<span class=\"dot\"></span>&nbsp;day trip</div>\n      </a>\n      <a class=\"post-card\" href=\"/the-douro-valley-%E2%80%94-a-day-among-the-terraced-vines/\" rel=\"history\">\n        <div class=\"post-region\">Portugal · Douro</div>\n        <div class=\"post-title\">The Douro Valley: A Day Among the Terraced Vines</div>\n        <div class=\"post-excerpt\">East into the hand-cut hillsides that made the port, and the river that earned the city its name.</div>\n      <div class=\"post-meta\">1 day&nbsp;<span class=\"dot\"></span>&nbsp;Day Trip</div>\n      </a>\n      <a class=\"post-card\" href=\"/4-weeks-portugal-to-spain-by-rail-road/\" rel=\"history\">\n        <div class=\"post-region\">Iberia · Circuit</div>\n        <div class=\"post-title\">Portugal to Spain by Rail and Road</div>\n        <div class=\"post-excerpt\">The full thirty-day circuit — Porto to Barcelona, almost entirely overland, with the costs laid bare.</div>\n      <div class=\"post-meta\">4 weeks&nbsp;<span class=\"dot\"></span>&nbsp;Chronicle</div>\n      </a>\n    </div>\n  </div>\n</section></bodycopy></div></div></div></div>";
