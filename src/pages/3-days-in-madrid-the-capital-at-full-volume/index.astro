import BaseLayout from "../../layouts/BaseLayout.astro";

const pageContent = "<div id=\"T4281391803\" page-url=\"menu_web\" class=\"page pinned pinned-top fixed\"><a id=\"menu_web\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><header class=\"header-web\" role=\"banner\">\n  <br>\n  <div class=\"header-web__inner\">\n    <a class=\"header-web__brand\" href=\"#\" rel=\"home-page\">THERE &amp; BACK AGAIN</a>\n\n    <nav aria-label=\"Primary\" class=\"header-web__nav\">\n      <a class=\"header-web__link\" href=\"/chronicles/\" rel=\"history\">CHRONICLES</a>\n      <a class=\"header-web__link\" href=\"/by-region/\" rel=\"history\">BY REGION</a>\n      <a class=\"header-web__link\" href=\"/about-the-traveller/\" rel=\"history\">THE TRAVELLER</a>\n    </nav>\n  </div>\n  <br>\n</header>\n\n<hr class=\"header-rule\"></bodycopy></div></div></div><div style=\"margin-top: 0px; margin-bottom: 0px;\" class=\"pages\"><div id=\"Q4232740030\" page-url=\"3-days-in-madrid-the-capital-at-full-volume\" class=\"page\"><a id=\"3-days-in-madrid-the-capital-at-full-volume\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><!--  POST HERO  -->\n<section class=\"post-hero\">\n  <div class=\"post-route-strip\">\n    <span>Europe</span>&nbsp;· Spain · Madrid ·&nbsp;<span>Summer 2024</span>\n  </div>\n\n  <h1 class=\"post-hero-title\"><em>3 Days in Madrid</em>:<br>\nThe Capital at Full Volume</h1>\n  <p class=\"post-hero-sub\">Two dense nights in the loudest, hungriest city of the trip — the world's oldest restaurant, a market lunch, the Arab baths, and Guernica in the quiet.</p>\n  <div class=\"post-stats\">\n    <div class=\"stat\"><span class=\"stat-num\">2</span><span class=\"stat-label\">Nights</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">1725</span><span class=\"stat-label\">Oldest Restaurant</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">Guernica</span><span class=\"stat-label\">Reina Sofía</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">~A$132</span><span class=\"stat-label\">2-Night Stay</span></div>\n  </div>\n</section>\n\n<!--  OPENING: THE ARRIVAL  -->\n<section class=\"opening-prose\">\n  <div class=\"narrative\">\n    <div class=\"prose\">\n      <p class=\"drop-cap\">After the silence of the stones — Évora's bones, Cáceres's storks, the long empty plains of the interior — Madrid hits like a wall of sound. The fast train sets the traveller down in the middle of a city running at full volume: nine o'clock at night and the streets are a river, the bars three deep, the children still out, the dinner not yet started, the whole capital behaving as though sleep were a rumour and the night were the point of the day. Madrid is not beautiful the way Lisbon is beautiful or grand the way Paris is grand. Madrid is <em>intense</em>. It is a city of appetite — for food, for talk, for late hours, for life lived loudly in public — and it makes no apology for any of it.</p>\n      <p>So the way to read Madrid, on a short two-night stay wedged into a long overland trip, is through the appetite. Skip the obligation to see everything; the Prado and the Royal Palace and El Retiro will keep. Instead let the city show itself the way it most wants to: at the table. Eat at the oldest restaurant on earth, lunch standing up in the great market, drink chocolate at midnight, and judge the place by how seriously it takes its pleasures. Madrid takes them very seriously indeed, and that seriousness turns out to be the most honest thing about it.</p>\n      <p>But under the noise there is a reckoning, too — one painting in one museum that the whole intense, life-loving city is, in part, built over. The appetite and the wound, side by side. That is Madrid.</p>\n    </div>\n  </div>\n</section>\n\n<!--  CHAPTER I  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter I</div>\n    <h2 class=\"chapter-name\"><em>The</em> Appetite</h2>\n    <p class=\"chapter-epithet\">The oldest restaurant, the market, and the midnight chocolate</p>\n\n    <div class=\"prose\">\n      <p>Begin where Madrid has been beginning dinner since 1725: <strong>Sobrino de Botín</strong>, certified by Guinness as the oldest restaurant in the world, its wood-fired oven never let go cold for three hundred years. The thing to order is the <em>cochinillo asado</em> — suckling pig roasted until the skin shatters like glass and the meat falls off the bone — eaten in low-ceilinged rooms where Goya is said to have washed dishes and Hemingway set the last scene of <em>The Sun Also Rises</em>. It is touristy, and it does not matter; the pig is extraordinary and the weight of the years in the room is real. This is eating as history, the city's appetite stretched across three centuries and still going.</p>\n      <p>By day the appetite moves to the <strong>Mercado de San Miguel</strong>, the beautiful iron-and-glass market beside the Plaza Mayor, now a temple of stand-up grazing — a counter of <em>jamón</em>, an oyster bar, croquetas, vermouth on tap, the whole Spanish larder served in small plates to be eaten elbow to elbow. Out in the tapas bars the city eats in motion, a bite and a drink and on to the next. And then, because Madrid does not believe the night should end, there is <strong>Chocolatería San Ginés</strong>, pouring thick dark drinking chocolate and crisp <em>churros</em> since 1894, very nearly around the clock — the right way to close a Madrid night is dipping churros into chocolate at midnight with the bars still roaring outside. For something to carry away, <strong>La Violeta</strong> sells its century-old candied violet sweets in a tiny jewel-box shop. The whole day, dawn to small hours, is organised around the mouth.</p>\n    </div>\n  </div>\n\n  <aside class=\"pull\">\n    <p>Judge the place by how seriously it takes its pleasures. Madrid takes them very seriously indeed.</p>\n  </aside>\n</section>\n\n<!--  CHAPTER II  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter II</div>\n    <h2 class=\"chapter-name\"><em>The</em> Painting</h2>\n    <p class=\"chapter-epithet\">Guernica, and the wound under the noise</p>\n\n    <div class=\"prose\">\n      <p>There is one thing in Madrid that demands to be seen quietly, and it is a single painting. In the <strong>Museo Reina Sofía</strong> hangs Picasso's <strong>Guernica</strong> — the vast grey-black-and-white canvas he painted in 1937 in fury and grief after Nazi planes, at Franco's invitation, firebombed the defenceless Basque town of Gernika in an afternoon. The screaming horse, the broken sword, the woman with the lamp, the mother and the dead child: it is the twentieth century's greatest anti-war painting, and standing in front of it — far larger than any reproduction prepares you for — the noise of the appetite-city falls away. Picasso refused to let the work come home to Spain while Franco lived. It arrived only in 1981, after the dictator was dead and the country a democracy again, and there is a sense, still, in which the whole loud life-loving city outside the museum is dancing on a grave it has only recently been allowed to mark.</p>\n      <p>That is the other half of Madrid, and the trip is honest enough to sit with it. The intensity, the late nights, the appetite for life in public — some of it is the specific exuberance of a society that spent forty years under a dictatorship told to keep quiet, and got the volume back. To understand the joy you have to see the wound. Afterwards the traveller walks it off in the late sun, perhaps out to the <strong>Templo de Debod</strong> — a genuine ancient Egyptian temple, gifted to Spain and rebuilt stone by stone in a park, where the city gathers to watch the sun go down behind two-thousand-year-old gateways. The capital at full volume, taking a breath.</p>\n    </div>\n  </div>\n</section>\n\n<!--  CHAPTER III  -->\n<section class=\"chapter-break\">\n  <div class=\"narrative\">\n    <div class=\"chapter-number\">Chapter III</div>\n    <h2 class=\"chapter-name\"><em>The</em> Slow Hour</h2>\n    <p class=\"chapter-epithet\">The Arab baths, the bookshops, and a different pace</p>\n\n    <div class=\"prose\">\n      <p>For all its volume, Madrid keeps a few quiet rooms, and the trip went looking for them. Beneath the streets near Sol, the <strong>Hammam Al Ándalus</strong> revives the Moorish bathing tradition that Spain spent centuries trying to forget: a candlelit warren of hot, warm and cold pools under horseshoe arches, steam and tilework and silence, where ninety minutes of drifting between the waters does more for the legs of a long overland trip than any amount of sleep. After weeks of buses and trains and cobbled climbs, it is the single most restorative hour of the journey — the hard-driving capital, of all places, offering the deepest rest.</p>\n      <p>The other quiet pleasure is paper. Madrid keeps a tradition of <strong>antiquarian bookshops</strong> — names like <strong>Miranda</strong> and <strong>Bardón</strong> — dim rooms of old maps, prints and leather spines, where an hour disappears without notice and the city's noise is shut out by the weight of the stock. Between the bath and the books, a Madrid day finds its counter-rhythm: the appetite and the intensity balanced, just, by steam and old paper. And then it is morning, and the short dense stay is over, and the train south to Valencia is waiting — out of the high dry capital, back down toward the Mediterranean light.</p>\n    </div>\n  </div>\n</section>\n\n<div class=\"ornament\">· · · ✦ · · ·</div>\n\n<div class=\"beat\">The appetite and the wound, side by side. That is Madrid.</div>\n\n<!--  PRACTICAL: GETTING THERE  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Getting There &amp; Around</div>\n    <div class=\"prac-dates\">Madrid · Summer 2024</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">By Train</div>\n    <div class=\"prac-item\"><strong>From Cáceres</strong> — fast trains in around <strong>3.5 hours</strong>, into Atocha.</div>\n    <div class=\"prac-item\"><strong>Onward to Valencia</strong> — a fast <strong>train, under 2 hours</strong> (roughly <strong>A$52</strong>), east to the Mediterranean.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Getting Around &amp; Staying</div>\n    <div class=\"prac-item\">The centre is walkable; the <strong>metro</strong> is cheap, fast and covers the rest. A <em>Multi</em> card works across the network.</div>\n    <div class=\"prac-item\"><strong>Far From Home Gran Vía</strong> — central on the great boulevard, walk-everywhere. Roughly <strong>A$132 for the two nights</strong>.</div>\n  </div>\n</section>\n\n<!--  PRACTICAL: SITES & TICKETS  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Sites &amp; Tickets</div>\n    <div class=\"prac-dates\">Costs in AUD (€ locked)</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Art &amp; Baths</div>\n    <div class=\"prac-item\"><strong>Museo Reina Sofía</strong> (Guernica) — around <strong>A$20 (€12)</strong>; <strong>free</strong> weekday evenings (from 7pm) and Sunday afternoon.</div>\n    <div class=\"prac-item\"><strong>Hammam Al Ándalus</strong> (Arab baths) — a 90-minute session ran about <strong>A$99</strong>; book a slot ahead.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Free &amp; Classic</div>\n    <div class=\"prac-item\"><strong>Templo de Debod</strong> — free; go for sunset. <strong>Mercado de San Miguel</strong> — free to enter; pay by the plate.</div>\n    <div class=\"prac-item\"><strong>The Prado &amp; Royal Palace</strong> — the classics, if the two days stretch; both reward a skip-the-line ticket.</div>\n  </div>\n</section>\n\n<!--  PRACTICAL: EATING & DRINKING  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Eating &amp; Drinking</div>\n    <div class=\"prac-dates\">The trip's table</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">The Big Ones</div>\n    <div class=\"prac-item\"><strong>Sobrino de Botín</strong> — the world's oldest restaurant (1725); order the <em>cochinillo asado</em>. Book ahead.</div>\n    <div class=\"prac-item\"><strong>Mercado de San Miguel</strong> — stand-up grazing beside the Plaza Mayor: jamón, oysters, croquetas, vermouth.</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">Local &amp; Sweet</div>\n    <div class=\"prac-item\"><strong>Taberna de la Elisa</strong> — the relaxed neighbourhood dinner; tapas and a good local list.</div>\n    <div class=\"prac-item\"><strong>Chocolatería San Ginés</strong> — thick chocolate and <em>churros</em>, near-round-the-clock since 1894. <strong>La Violeta</strong> — candied violet sweets to take away.</div>\n  </div>\n</section>\n\n<!--  PRACTICAL: TIPS & WATCH-OUTS  -->\n<section class=\"practical\">\n  <div class=\"prac-header\">\n    <div class=\"prac-city\">Tips &amp; Watch-outs</div>\n    <div class=\"prac-dates\">For the two days</div>\n  </div>\n\n  <div class=\"prac-section\">\n    <div class=\"prac-label\">On the Ground</div>\n    <div class=\"tip-row\"><strong>Eat on Madrid time.</strong> Lunch 2–3pm, dinner 9–10pm or later. Turn up at 7 and you'll have the place to yourself — and not in a good way.</div>\n    <div class=\"tip-row\"><strong>See Guernica quietly, and ideally free.</strong> The Reina Sofía is free weekday evenings and Sunday afternoons; go then and give the painting room.</div>\n    <div class=\"tip-row\"><strong>Book the Arab baths ahead.</strong> Sessions are timed and sell out, especially evenings.</div>\n    <div class=\"tip-row\"><strong>Templo de Debod at sunset</strong> is a local ritual — arrive early for a spot on the grass.</div>\n    <div class=\"tip-row\"><strong>Madrid is late, loud and safe</strong> — but Gran Vía and Sol draw pickpockets. Usual care in the crush.</div>\n  </div>\n</section>\n\n<!--  VIATOR TOURS  -->\n<div class=\"tours\">\n  <div class=\"tours-label\">Guided Experiences — Madrid</div>\n  <div class=\"tours-grid\">\n    <a class=\"tour-card\" href=\"https://www.viator.com/tours/Madrid/Madrid-Tapas-and-Wine-Tasting-Tour/d566-5830WINETAPAS?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n      <div class=\"tour-type\">Food &amp; Wine</div>\n      <div class=\"tour-name\">Madrid Tapas &amp; Wine Tasting Small-Group Tour</div>\n      <div class=\"tour-meta\">The city read the way it wants to be — through the appetite, bar to bar, a bite and a glass at each.</div>\n      <div class=\"tour-footer\">\n        <span class=\"tour-price\">From ~A$120</span>\n        <span class=\"tour-link-label\">View on Viator →</span>\n      </div>\n    </a>\n    <a class=\"tour-card\" href=\"https://www.viator.com/tours/Madrid/Madrids-Prado-Museum-Expert-Guided-Tour-with-skip-the-line/d566-56823P14?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n      <div class=\"tour-type\">Art</div>\n      <div class=\"tour-name\">Prado Museum Skip-the-Line Expert Guided Tour</div>\n      <div class=\"tour-meta\">The other great Madrid art stop — Velázquez, Goya and the Spanish masters, with the queue skipped.</div>\n      <div class=\"tour-footer\">\n        <span class=\"tour-price\">From ~A$70</span>\n        <span class=\"tour-link-label\">View on Viator →</span>\n      </div>\n    </a>\n    <a class=\"tour-card\" href=\"https://www.viator.com/tours/Madrid/Tablao-Flamenco-las-Tablas-Madrid-Admission-Ticket/d566-90395P1?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n      <div class=\"tour-type\">Flamenco</div>\n      <div class=\"tour-name\">Tablao Flamenco Las Tablas — Show Admission</div>\n      <div class=\"tour-meta\">A night of live flamenco in a Madrid <em>tablao</em> — the volume turned, for an hour, into stamp and guitar.</div>\n      <div class=\"tour-footer\">\n        <span class=\"tour-price\">From ~A$60</span>\n        <span class=\"tour-link-label\">View on Viator →</span>\n      </div>\n    </a>\n  </div>\n</div>\n\n<!--  ITINERARY  -->\n<section class=\"itin-block\">\n  <div class=\"itin-inner\">\n    <div class=\"itin-block-title\">Two Days in Madrid at a Glance</div>\n\n    <p class=\"itin-meta\">Shape: <strong>a short, dense capital stop, read through appetite and intensity</strong>.</p>\n    <p class=\"itin-meta\">Stay: <strong>Far From Home Gran Vía, ~A$132 / 2 nights</strong>.</p>\n\n    <div class=\"itin-section-head\">Madrid — compressed</div>\n    <div class=\"itin-days\">\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Eve 1</span>Arrive from Cáceres. Dinner at <strong>Sobrino de Botín</strong> — the cochinillo — then the Gran Vía and chocolate and churros at San Ginés.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 2</span>The Hammam Al Ándalus baths at 10am; the antiquarian bookshops; lunch at the Mercado de San Miguel; <strong>Guernica</strong> at the Reina Sofía; the Templo de Debod at sunset; dinner at Taberna de la Elisa.</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">AM 3</span>A last coffee and a box of violets from La Violeta, then the fast train east to Valencia.</div>\n    </div>\n  </div>\n</section>\n\n<!--  CLOSING REFLECTION  -->\n<section class=\"post-closing\">\n  <div class=\"narrative\">\n    <div class=\"prose\">\n      <p>Madrid is the loudest, hungriest, most alive city of the whole trip, and it earns the volume. It is a capital that eats late and talks louder and stays up past everyone, and the easy mistake is to read all that as shallow — a city of pleasure with nothing underneath. But a single grey painting in a quiet museum corrects that fast. The joy is real, and it is hard-won; a society that was told to keep quiet for forty years got its voice back and has been using it ever since. To eat the three-hundred-year-old pig and then stand in front of <em>Guernica</em> is to understand both halves of the same city in an afternoon.</p>\n      <p>The traveller leaves the capital restored — fed, steamed, and quietly shaken — and takes the fast train down toward the coast. The high dry plateau falls away; the light softens; the Mediterranean is ahead now, and with it Valencia, where the river became a garden and the appetite turns, at last, to rice and the sea.</p>\n    </div>\n  </div>\n</section>\n\n<div class=\"beat\">But the road is ever onward.</div>\n\n<!--  FAQ  -->\n<section class=\"faq-block\">\n  <div class=\"faq-inner\">\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Is two days enough for Madrid?</div>\n      <div class=\"faq-a\">For a focused stop, yes. Two days is enough to eat extraordinarily well, see Guernica at the Reina Sofía, soak in the Arab baths, and feel the city's late-night intensity — though it leaves the Prado and the Royal Palace for a return. Treat a short Madrid stay as a deep dive into appetite and one great painting rather than a checklist.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Where should you eat in Madrid?</div>\n      <div class=\"faq-a\">Start with Sobrino de Botín, the world's oldest restaurant (1725), for roast suckling pig; graze the Mercado de San Miguel; do tapas crawls in the centre; and finish with chocolate and churros at the near-24-hour Chocolatería San Ginés. Eat on Madrid time — lunch at 2–3pm, dinner at 9–10pm.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Where is Guernica, and is it free?</div>\n      <div class=\"faq-a\">Picasso's Guernica hangs in the Museo Reina Sofía. General admission is around €12, but the museum is free on weekday evenings (from 7pm) and Sunday afternoons — the best time to see the painting with room to take it in.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">What are the Arab baths in Madrid?</div>\n      <div class=\"faq-a\">Hammam Al Ándalus, near Puerta del Sol, is a modern hammam reviving Spain's Moorish bathing tradition — candlelit hot, warm and cold pools under horseshoe arches. A 90-minute session is deeply restorative, especially mid-trip; book a timed slot in advance.</div>\n    </div>\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">How do you get from Madrid to Valencia?</div>\n      <div class=\"faq-a\">By high-speed train — under two hours, and frequent. Madrid sits at the centre of Spain's AVE network, making it an easy hub between Cáceres to the west and Valencia and Barcelona to the east.</div>\n    </div>\n  </div>\n</section>\n\n\n\n<!--  FURTHER READING  -->\n<section class=\"next-chronicles\">\n  <div class=\"narrative\">\n    <h2 class=\"chapter-name\" style=\"text-align:center; margin-bottom: 2.5rem;\"><em>Further</em> Reading</h2>\n    <div class=\"posts-grid\">\n      <a class=\"post-card\" href=\"/4-days-in-valencia-itinerary/\" rel=\"history\">\n        <div class=\"post-region\">Spain · Valencia</div>\n        <div class=\"post-title\">Valencia: Where the River Became a Garden</div>\n        <div class=\"post-excerpt\">East to the Mediterranean — paella's birthplace, a dry riverbed turned into a park, and the City of Arts.</div>\n      <div class=\"post-meta\">4 days&nbsp;<span class=\"dot\"></span>&nbsp;Chronicle</div>\n      </a>\n      <a class=\"post-card\" href=\"/2-days-in-c%C3%A1ceres-a-medieval-city-held-in-amber/\" rel=\"history\">\n        <div class=\"post-region\">Spain · Extremadura</div>\n        <div class=\"post-title\">Cáceres: A Medieval City Held in Amber</div>\n        <div class=\"post-excerpt\">The stop before the capital — a walled old town frozen in golden stone, with storks on the towers.</div>\n      <div class=\"post-meta\">2 days&nbsp;<span class=\"dot\"></span>&nbsp;City Guide</div>\n      </a>\n      <a class=\"post-card\" href=\"/4-weeks-portugal-to-spain-by-rail-road/\" rel=\"history\">\n        <div class=\"post-region\">Iberia · Circuit</div>\n        <div class=\"post-title\">Portugal to Spain by Rail and Road</div>\n        <div class=\"post-excerpt\">The full thirty-day circuit — Porto to Barcelona, almost entirely overland, with the costs laid bare.</div>\n      <div class=\"post-meta\">4 weeks&nbsp;<span class=\"dot\"></span>&nbsp;Chronicle</div>\n      </a>\n    </div>\n  </div>\n</section></bodycopy></div></div></div></div>";
