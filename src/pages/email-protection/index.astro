---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageContent = "\n  <div id=\"cf-wrapper\">\n    <div class=\"cf-alert cf-alert-error cf-cookie-error\" id=\"cookie-alert\" data-translate=\"enable_cookies\">Please enable cookies.</div>\n    <div id=\"cf-error-details\" class=\"cf-error-details-wrapper\">\n      <div class=\"cf-wrapper cf-header cf-error-overview\">\n        <h1 data-translate=\"block_headline\">Email Protection</h1>\n        <h2 class=\"cf-subheadline\"><span data-translate=\"unable_to_access\">You are unable to access this email address</span> mitchchadban.com</h2>\n      </div><!-- /.header -->\n\n      <div class=\"cf-section cf-wrapper\">\n        <div class=\"cf-columns two\">\n          <div class=\"cf-column\">\n            <p>The website from which you got to this page is protected by Cloudflare. Email addresses on that page have been hidden in order to keep them from being accessed by malicious bots. <strong>You must enable Javascript in your browser in order to decode the e-mail address</strong>.</p>\n            <p>If you have a website and are interested in protecting it in a similar way, you can <a rel=\"noopener noreferrer\" href=\"https://www.cloudflare.com/sign-up?utm_source=email_protection\">sign up for Cloudflare</a>.</p>\n          </div>\n\n          <div class=\"cf-column\">\n            <div class=\"grid_4\">\n              <div class=\"rail\">\n                  <div class=\"panel\">\n                      <ul class=\"nobullets\">\n                        <li><a rel=\"noopener noreferrer\" class=\"modal-link-faq\" href=\"https://developers.cloudflare.com/waf/tools/scrape-shield/email-address-obfuscation/\">How does Cloudflare protect email addresses on website from spammers?</a></li>\n                        <li><a rel=\"noopener noreferrer\" class=\"modal-link-faq\" href=\"https://developers.cloudflare.com/fundamentals/setup/account/create-account/\">Can I sign up for Cloudflare?</a></li>\n                    </ul>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div><!-- /.section -->\n\n      <div class=\"cf-error-footer cf-wrapper w-240 lg:w-full py-10 sm:py-4 sm:px-8 mx-auto text-center sm:text-left border-solid border-0 border-t border-gray-300\">\n    <p class=\"text-13\">\n      <span class=\"cf-footer-item sm:block sm:mb-1\">Cloudflare Ray ID: <strong class=\"font-semibold\">a0f12d3a58c8a34c</strong></span>\n      <span class=\"cf-footer-separator sm:hidden\">•</span>\n      <span id=\"cf-footer-item-ip\" class=\"cf-footer-item hidden sm:block sm:mb-1\">\n        Your IP:\n        <button type=\"button\" id=\"cf-footer-ip-reveal\" class=\"cf-footer-ip-reveal-btn\">Click to reveal</button>\n        <span class=\"hidden\" id=\"cf-footer-ip\">2403:4800:2408:3626:5cb0:4da4:b5d7:bbe3</span>\n        <span class=\"cf-footer-separator sm:hidden\">•</span>\n      </span>\n      <span class=\"cf-footer-item sm:block sm:mb-1\"><span>Performance &amp; security by</span> <a rel=\"noopener noreferrer\" href=\"https://www.cloudflare.com/5xx-error-landing\" id=\"brand_link\" target=\"_blank\">Cloudflare</a></span>\n      \n    </p>\n    \n  </div><!-- /.error-footer -->\n\n    </div><!-- /#cf-error-details -->\n  </div><!-- /#cf-wrapper -->\n\n    \n\n\n";
---

<BaseLayout
  title="Email Protection | Cloudflare"
  description="A literary travel chronicle by Mitch Chadban."
  canonical="https://travel.mitchchadban.com/email-protection/"
>
  <Fragment set:html={pageContent} />
</BaseLayout>
