import BaseLayout from "../../layouts/BaseLayout.astro";

const pageContent = "<div id=\"T4281391803\" page-url=\"menu_web\" class=\"page pinned pinned-top fixed\"><a id=\"menu_web\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><header class=\"header-web\" role=\"banner\">\n  <br>\n  <div class=\"header-web__inner\">\n    <a class=\"header-web__brand\" href=\"#\" rel=\"home-page\">THERE &amp; BACK AGAIN</a>\n\n    <nav aria-label=\"Primary\" class=\"header-web__nav\">\n      <a class=\"header-web__link\" href=\"/chronicles/\" rel=\"history\">CHRONICLES</a>\n      <a class=\"header-web__link\" href=\"/by-region/\" rel=\"history\">BY REGION</a>\n      <a class=\"header-web__link\" href=\"/about-the-traveller/\" rel=\"history\">THE TRAVELLER</a>\n    </nav>\n  </div>\n  <br>\n</header>\n\n<hr class=\"header-rule\"></bodycopy></div></div></div><div style=\"margin-top: 0px; margin-bottom: 0px;\" class=\"pages\"><div id=\"M1248982363\" page-url=\"2-days-in-fez-itinerary\" class=\"page\"><a id=\"2-days-in-fez-itinerary\"></a><div class=\"page-layout\"><div class=\"page-content\"><bodycopy style=\"--fit-height: 10px; --resize-parent-width: 100%;\"><!--  SCHEMA BLOCK — paste into Cargo page settings > Custom Code > Head  -->\n<!-- \n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [\n    {\n      \"@type\": \"Article\",\n      \"@id\": \"https://thereandbackagain.blog/fez-travel-guide\",\n      \"headline\": \"Fez Travel Guide: 2 Days in Morocco's Ancient Imperial City\",\n      \"description\": \"A solo traveller's guide to Fez, Morocco — the medina, the tanneries, where to eat, where to stay, and how to survive the world's largest car-free city.\",\n      \"author\": { \"@type\": \"Person\", \"name\": \"The Traveller\" },\n      \"publisher\": { \"@type\": \"Organization\", \"name\": \"There and Back Again\" },\n      \"url\": \"https://thereandbackagain.blog/fez-travel-guide\",\n      \"inLanguage\": \"en\"\n    },\n    {\n      \"@type\": \"TravelGuide\",\n      \"name\": \"Fez, Morocco — Solo Travel Guide\",\n      \"description\": \"Complete guide to visiting Fez el-Bali, Morocco's oldest and largest medina, including the Chouara Tanneries, Bou Inania Medersa, where to eat traditional Fassi cuisine, and practical transport and accommodation information.\",\n      \"touristType\": \"Solo traveller\",\n      \"url\": \"https://thereandbackagain.blog/fez-travel-guide\"\n    },\n    {\n      \"@type\": \"FAQPage\",\n      \"mainEntity\": [\n        {\n          \"@type\": \"Question\",\n          \"name\": \"How many days do you need in Fez?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Two full days is the minimum to do Fez justice. Day one covers the Fes el-Jdid quarter, the Royal Palace, and the Mellah. Day two goes deep into Fes el-Bali — the tanneries, Al-Attarine Madrasa, Al-Qarawiyyin, and Bou Inania Medersa. A third day allows for slower wandering and the Marinid Tombs at dusk.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"Is Fez safe for solo travellers?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Fez is generally safe for solo travellers. The medina can be disorienting and unofficial guides will approach you constantly — politely decline or ignore them. If you do get genuinely lost, locals are almost universally helpful. Budget around 100–200 dirhams if someone assists you back to a landmark.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"What is the best way to get to Fez from Rabat?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"The ONCF train from Rabat Ville to Gare de Fès is the best option — comfortable, reliable, and scenic. The journey takes approximately 2 hours 30 minutes. Trains run frequently throughout the day. Second class is perfectly adequate and costs around 100–120 dirhams.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"What does the Chouara Tannery smell like?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"The Chouara Tannery smells strongly of ammonia from the pigeon dung used in the leather-curing process. It is pungent but manageable. Shops overlooking the tanneries often offer sprigs of mint to hold under your nose — accept them. The visual spectacle from above more than compensates.\"\n          }\n        },\n        {\n          \"@type\": \"Question\",\n          \"name\": \"Where should I stay in Fez?\",\n          \"acceptedAnswer\": {\n            \"@type\": \"Answer\",\n            \"text\": \"Stay inside Fes el-Bali, the old medina. The Golden Triangle — the area bounded by the Mausoleum of Moulay Idriss, Al-Qarawiyyin University, and the Mausoleum of Sidi Ahmed Tijani — is the ideal location. You will be steps from everything and immersed in the city as it actually lives. A traditional dar or riad here puts you inside the museum, not outside it.\"\n          }\n        }\n      ]\n    },\n    {\n      \"@type\": \"BreadcrumbList\",\n      \"itemListElement\": [\n        { \"@type\": \"ListItem\", \"position\": 1, \"name\": \"Home\", \"item\": \"https://thereandbackagain.blog\" },\n        { \"@type\": \"ListItem\", \"position\": 2, \"name\": \"Africa\", \"item\": \"https://thereandbackagain.blog/chronicles?region=africa\" },\n        { \"@type\": \"ListItem\", \"position\": 3, \"name\": \"Fez Travel Guide\", \"item\": \"https://thereandbackagain.blog/fez-travel-guide\" }\n      ]\n    }\n  ]\n}\n</script>\n -->\n\n<!--  META — paste into Cargo page settings > Custom Code > Head  -->\n<!-- \n<title>Fez Travel Guide: 2 Days in Morocco's Ancient Medina | There and Back Again</title>\n<meta name=\"description\" content=\"Inside the world's largest car-free city: a solo traveller's guide to Fez el-Bali — tanneries, madrasas, Fassi feasts, and getting gloriously lost.\">\n<meta property=\"og:title\" content=\"Fez Travel Guide: 2 Days in Morocco's Ancient Medina\">\n<meta property=\"og:description\" content=\"Inside the world's largest car-free city: a solo traveller's guide to Fez el-Bali — tanneries, madrasas, Fassi feasts, and getting gloriously lost.\">\n<meta property=\"og:url\" content=\"https://thereandbackagain.blog/fez-travel-guide\">\n<meta property=\"og:type\" content=\"article\">\n<link rel=\"canonical\" href=\"https://thereandbackagain.blog/fez-travel-guide\">\n -->\n\n<!--  ═══════════════════════════════════════════════════  -->\n<!--  PAGE 8 — FEZ DEEP-DIVE POST                         -->\n<!--  Paste everything below into Cargo page code embed   -->\n<!--  ═══════════════════════════════════════════════════  -->\n\n<div class=\"post-hero\">\n  <div class=\"post-route-strip\">\n    <span>Africa</span>&nbsp;· Morocco ·&nbsp;<span>Imperial Circuit</span>\n  </div>\n  <h1 class=\"post-hero-title\"><em>Fez:</em> Into the Labyrinth<br>\nof the Eternal City</h1>\n  <p class=\"post-hero-sub\">Two days inside Fez el-Bali — the world's oldest living medina, and the place that resists all description</p>\n  <div class=\"post-stats\">\n    <div class=\"stat\"><span class=\"stat-num\">2</span><span class=\"stat-label\">Days</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">9,000</span><span class=\"stat-label\">Alleys</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">1,200</span><span class=\"stat-label\">Years Old</span></div>\n    <div class=\"stat\"><span class=\"stat-num\">~$120</span><span class=\"stat-label\">AUD / Day</span></div>\n  </div>\n</div>\n\n<div class=\"post-body\">\n\n  <div class=\"opening-prose narrative\">\n    <div class=\"prose\">\n      <p class=\"drop-cap\">There are cities that present themselves plainly — their monuments arranged for the visitor, their streets laid in grids, their meaning legible at a glance. And then there is Fez. Fez does not present itself. Fez swallows you whole, turns you around three times in the dark, and hands you back to yourself somewhat changed, somewhat humbled, and completely unable to explain what just happened. This is a city that has been continuously inhabited since the ninth century of the mortal calendar, and it shows — not in the manner of a museum, but in the manner of a living thing that has simply never stopped.</p>\n      <p>The traveller arrived by rail from the north, the steel serpent depositing them at Gare de Fès in the early hours of the afternoon on the twenty-first day of the third month. The train had been pleasant enough — Morocco's rail runs reliably and with a certain quiet dignity — though comfort in the conventional sense had been modest. No matter. What awaited on the platform more than compensated.</p>\n      <p>Fez is, in practical terms, two cities: the modern Ville Nouvelle, broad and French in its bones, and Fes el-Bali — the old medina, the original, the one that matters. The largest car-free urban zone on earth. A place where donkeys still carry goods through passages so narrow that two laden animals cannot pass each other, where the call to prayer echoes off walls that have heard a thousand years of the same words, where the smell of tannery and spice and cedar smoke has soaked so deep into the stone that the stone itself seems perfumed. The traveller had seen Marrakech. They thought they understood Morocco. They did not.</p>\n    </div>\n  </div>\n\n  <div class=\"chapter-break narrative\">\n    <div class=\"chapter-number\">Chapter I</div>\n    <h2 class=\"chapter-name\"><em>Le Petit Bijou</em></h2>\n    <p class=\"chapter-epithet\">A jewel in the Golden Triangle — 14th century walls, and a courtyard that stops the breath</p>\n    <div class=\"weather-badge\">\n      <span>Fez · March</span>\n      <span class=\"w-hi\">↑ 32°C</span>\n      <span class=\"w-lo\">↓ 17°C</span>\n    </div>\n    <div class=\"prose\">\n      <p>The dar had no sign. There was a street — if the word street can be applied to something barely wide enough to extend both arms — and there was a door, ancient and studded with iron, set into a wall that gave nothing away. This is the genius of the Fez medina's architecture: all its beauty faces inward. The world outside sees only stone. Step through the threshold and the revelation is absolute.</p>\n      <p>Dar Le Petit Bijou dates from the fourteenth century, and its renovation has been done with the reverence such age demands — zellige tilework in geometric patterns that seem to fracture light into mathematics, cedar wood carved into lace overhead, tadelakt walls smooth as old silk, bronze lamps hammered entirely by hand. The leather of the sofas came from the tanneries scarcely a minute's walk away. The patio breathed cool air upward from the stone. The traveller set down their pack and stood very still for a moment, the way one does when something exceeds all reasonable expectation.</p>\n      <p>The dar sits in what its hosts call the Golden Triangle — the small sacred precinct bounded by the Mausoleum of Moulay Idriss, the great Al-Qarawiyyin University, and the Mausoleum of Sidi Ahmed Tijani, all within four hundred metres of one another. To sleep here is not to be near the medina. It is to be inside it, fully, without qualification. The nearest road that a car might use is a world away.</p>\n    </div>\n  </div>\n\n  <div class=\"practical narrative\">\n    <div class=\"prac-header\">\n      <span class=\"prac-city\">📍 Fez — Accommodation</span>\n      <span class=\"prac-dates\">Nights of 21–22 March</span>\n    </div>\n    <div class=\"prac-section\">\n      <div class=\"prac-label\">Where to Stay</div>\n      <div class=\"prac-item\"><strong>Dar Le Petit Bijou</strong> — 28 Znikat Hajjama, Fes el-Bali. A 14th-century dar in the Golden Triangle, renovated with traditional zellige, cedar, and tadelakt. Three bedrooms, each with private bathroom, a hammam, Moroccan salon, patio, and rooftop terrace. Entire property rental only. Hosted by Khalid and Fouzia, who also offer optional traditional Fassi breakfasts (65 MAD/person) and dinners (125 MAD/person). Book via <a href=\"https://www.airbnb.com.au/rooms/7023629\" style=\"color:#7db05a;\">Airbnb</a>.</div>\n      <div class=\"prac-item\"><strong>Neighbourhood:</strong> Stay inside Fes el-Bali. The Golden Triangle location puts you within walking distance of every major site. There are no cars. There is no noise beyond the city's own ancient sounds.</div>\n      <div class=\"prac-item\"><strong>Arrival note:</strong> The medina is a no-car zone. Check-in times are check-in at 14:00 / check-out at 10:00. Your host will meet you — coordinate arrival in advance. Luggage on foot through the alleys is part of the experience.</div>\n    </div>\n    <div class=\"prac-section\">\n      <div class=\"prac-label\">Budget Snapshot</div>\n      <div class=\"budget-grid\">\n        <div class=\"budget-cell\"><div class=\"budget-cat\">Accommodation</div><div class=\"budget-val\">~$90 AUD/night</div></div>\n        <div class=\"budget-cell\"><div class=\"budget-cat\">Food daily</div><div class=\"budget-val\">~$40–60 AUD</div></div>\n        <div class=\"budget-cell\"><div class=\"budget-cat\">Transport</div><div class=\"budget-val\">~$10 AUD</div></div>\n        <div class=\"budget-cell\"><div class=\"budget-cat\">Daily total</div><div class=\"budget-val\">~$140–160 AUD</div></div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"beat\">First night in the oldest city in the world.</div>\n\n  <div class=\"chapter-break narrative\">\n    <div class=\"chapter-number\">Chapter II</div>\n    <h2 class=\"chapter-name\">The Palace on the <em>Roof of the World</em></h2>\n    <p class=\"chapter-epithet\">Dinner at Mouda Palace — the medina spread below like a map of all time</p>\n    <div class=\"prose\">\n      <p>On the first evening, the traveller climbed. The Restaurant Lounge sur le Toit du Palais de Mouda occupies the rooftop of one of Fez's old palaces on Rue Talaa Sghira, and to reach one's table is to ascend through layers of the city's history — carved plaster, painted ceilings, the gradual opening of space — until finally the terrace presents itself and the whole of the medina falls away below in every direction. The minarets needle the sky. The warren of rooftops, each one a little different, extends to the hills where the Marinid Tombs keep their long watch over the city they once ruled. The call to prayer, when it came, seemed to rise from the city itself rather than from any single source.</p>\n      <p>The food was traditional Fassi — the cuisine of Fez, which differs from what the rest of Morocco eats in the way that court cooking differs from country cooking. Fez was the imperial capital, the seat of learning, the place where the scholars and the sultans ate. The cooking reflects this. Rich, complex, patient. The traveller ordered kefta — spiced minced lamb shaped into small meatballs and cooked in a sauce of tomato and cumin and something warmer underneath that resisted identification, served with bread for tearing, eaten slowly, with the medina spread below and the first stars arriving above the minarets. It was, in the way that simple food eaten in the right place often is, close to perfect. The booking had been secured in advance, which is advisable: tables here are not easily found on the night.</p>\n    </div>\n  </div>\n\n  <div class=\"practical narrative\">\n    <div class=\"prac-header\">\n      <span class=\"prac-city\">📍 Fez — Where to Eat</span>\n      <span class=\"prac-dates\">Restaurants</span>\n    </div>\n    <div class=\"prac-section\">\n      <div class=\"prac-label\">The Three Meals</div>\n      <div class=\"prac-item\"><strong>Restaurant Lounge sur le Toit du Palais de Mouda</strong> — Rue Talaa Sghira. Rooftop terrace above an old palace with sweeping views across the medina. Traditional Fassi cuisine — the kefta meatballs in spiced tomato sauce are excellent, eaten with the medina below and the minarets above. Dinner booking essential: 7:30pm recommended. ~150–220 MAD per person.</div>\n      <div class=\"prac-item\"><strong>Restaurant Ryad Nejjarine</strong> — Derb El Achchabine, near the Nejjarine Fountain. A beautiful riad setting for lunch, in the heart of the old medina's most atmospheric quarter. Traditional tagines, fresh salads, mint tea. ~100–150 MAD per person.</div>\n      <div class=\"prac-item\"><strong>Dar Roumana</strong> — One of Fez's most celebrated fine-dining experiences. Modern Moroccan cuisine drawing on the city's Andalusian and Sephardic heritage, in a stunning 15th-century townhouse near the Marinid Tombs. The menu changes seasonally — the jamón with local ricotta and fresh nectarine salad is a masterclass in contrast; the Sephardic orange and almond cake with crème is the best way to end a meal in Morocco. Booking essential: 7:30pm. ~350–500 MAD per person.</div>\n    </div>\n    <div class=\"prac-section\">\n      <div class=\"prac-label\">Tips &amp; Watch-outs</div>\n      <div class=\"tip-row\">Book Mouda Palace and Dar Roumana well in advance — both fill quickly and neither takes walk-ins reliably in high season.</div>\n      <div class=\"tip-row\">Street food in the medina is excellent and cheap. Msemen (flatbread), harira (soup), and fresh-squeezed orange juice cost next to nothing and are absolutely worth stopping for.</div>\n      <div class=\"tip-row\">Alcohol is not widely available in the medina. Neither Mouda Palace nor Ryad Nejjarine serves it. Dar Roumana may have wine — confirm when booking.</div>\n    </div>\n  </div>\n\n  <div class=\"tours narrative\">\n    <div class=\"tours-label\">Guided Experiences — Fez</div>\n    <div class=\"tours-grid\">\n      <a class=\"tour-card\" href=\"https://www.viator.com/tours/Fez/Fez-Medina-and-Tanneries-Half-Day-Walking-Tour/d5246-3689P5?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n        <div class=\"tour-type\">Walking Tour</div>\n        <div class=\"tour-name\">Fez Medina &amp; Tanneries Half-Day Tour</div>\n        <div class=\"tour-meta\">The tanneries, the madrasa, the Nejjarine quarter — with a guide who knows which alley leads where</div>\n        <div class=\"tour-footer\"><span class=\"tour-price\">From ~$35 USD</span><span class=\"tour-link-label\">View Tour →</span></div>\n      </a>\n      <a class=\"tour-card\" href=\"https://www.viator.com/tours/Fez/Full-Day-Tour-to-Meknes-and-Volubilis-from-Fez/d5246-5433P13?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n        <div class=\"tour-type\">Day Trip</div>\n        <div class=\"tour-name\">Meknes &amp; Volubilis Full-Day from Fez</div>\n        <div class=\"tour-meta\">Roman ruins and another imperial city — the road north from Fez into Morocco's ancient interior</div>\n        <div class=\"tour-footer\"><span class=\"tour-price\">From ~$45 USD</span><span class=\"tour-link-label\">View Tour →</span></div>\n      </a>\n      <a class=\"tour-card\" href=\"https://www.viator.com/tours/Fez/Private-Full-Day-Tour-to-Chefchaouen-from-Fez/d5246-61972P5?pid=P00295455&amp;mcid=42383&amp;medium=link\" rel=\"noopener\" target=\"_blank\">\n        <div class=\"tour-type\">Day Trip</div>\n        <div class=\"tour-name\">Chefchaouen Day Trip from Fez</div>\n        <div class=\"tour-meta\">The Blue City in the Rif Mountains — two hours north and a world apart from the medina's ochre labyrinth</div>\n        <div class=\"tour-footer\"><span class=\"tour-price\">From ~$55 USD</span><span class=\"tour-link-label\">View Tour →</span></div>\n      </a>\n    </div>\n  </div>\n\n  <div class=\"beat\">But the road is ever onward — and morning brought the medina.</div>\n\n  <div class=\"chapter-break narrative\">\n    <div class=\"chapter-number\">Chapter III</div>\n    <h2 class=\"chapter-name\">The <em>Labyrinth</em> Unbound</h2>\n    <p class=\"chapter-epithet\">Into Fes el-Bali — nine thousand alleys, twelve centuries of stone, and no map that tells the truth</p>\n    <div class=\"prose\">\n      <p class=\"drop-cap\">There is no way to prepare for Fes el-Bali. The medina of Marrakech is large. The medina of Fez is something else entirely — a different order of magnitude, a different order of experience. Nine thousand alleys, some barely shoulder-width, branching and reconnecting in patterns that defeat all logic and resist all memory. The traveller had walked medinas before. They had navigated souks and derbs and winding stone passages. None of it was preparation. None of it was even close.</p>\n      <p>The traveller descended into Fes el-Bali on the second morning through Bab Boujloud — the Blue Gate, its tiles indigo on the outside, green on the inner face — and was immediately absorbed. The city does not so much welcome visitors as incorporate them. The lanes narrow. The overhead passageways multiply. The light comes in vertical shafts between rooftops too close together to admit the sky in any useful quantity. Donkeys pass with loads of cedar wood. Schoolchildren stream past in the opposite direction. A man carries a door.</p>\n      <p>The traveller lost their way. This is not a failure in Fez; it is a rite of passage, and in truth it is how the city is best encountered — not on a route, but at the mercy of it. A group of young Moroccan men found the traveller consulting a phone that had long since lost its bearing, and with extraordinary kindness walked them back toward a recognisable landmark. The gesture cost those men twenty minutes of their afternoon. The traveller offered two hundred dirhams, which was accepted with grace. It was the best two hundred dirhams of the journey.</p>\n    </div>\n  </div>\n\n  <div class=\"pull narrative\">\n    <p>\"The medina of Fez is the largest car-free urban zone on earth. Nine thousand alleys. Twelve centuries of continuous habitation. There is nothing else like it.\"</p>\n  </div>\n\n  <div class=\"prose narrative\" style=\"max-width:1100px;margin:0 auto;\">\n    <p>The Chouara Tannery is the oldest working tannery in the world and one of the most striking sights the traveller encountered on the entire journey from Bologna to Seville. The view comes from above — leather shops on the surrounding balconies let visitors stand at their upper floors and look down into the great stone vats below, where hides soak in circles of colour: saffron yellow, poppy red, the deep indigo of sky at dusk. The smell arrives before the sight. Ammonia, sharp and unmistakable — the ancient result of pigeon dung used in the curing process, unchanged in method since the eleventh century. Pungent, yes. Bearable, yes. Worth it, absolutely.</p>\n    <p>The leather shops press sprigs of mint into visiting hands as a matter of tradition. The traveller accepted, held it briefly, and then pocketed it — preferring, in the end, to smell the place as it actually is. Some things should not be softened.</p>\n    <p>From the tanneries the traveller moved through the quarter of the craftsmen — Place Seffarine, where coppersmiths beat their wares against the persistent soundtrack of ringing metal — and to Al-Attarine Madrasa, the 14th-century theological school whose interior courtyard is perhaps the most beautiful single room encountered on the entire voyage. Zellige to shoulder height. Above that, stucco carved so fine it resembles lace. Above that, cedar screens filtering the light from the gallery above. The Marinids who built it were trying to make something worthy of the God they served. They succeeded.</p>\n    <p>Lunch was taken at Restaurant Ryad Nejjarine, seated in the cool of a restored riad courtyard with mint tea and a tagine of lamb and preserved lemon. Outside, the Nejjarine Fountain — carved cedar and painted tile, eighteenth century — stood in its square as it has always stood, while the city moved around it in the unhurried rhythm of a place that has survived far longer than hurry.</p>\n  </div>\n\n  <div class=\"ornament\">· · ✦ · ·</div>\n\n  <div class=\"prose narrative\" style=\"max-width:1100px;margin:0 auto;\">\n    <p>The second evening's dinner was at Dar Roumana, a short ascent from the medina floor toward the Marinid Tombs. The restaurant occupies a 15th-century townhouse, its dining rooms stacked across multiple levels, each one intimate and softly lit. The cooking is the finest the traveller ate in Morocco — modern in its technique, entirely Moroccan in its soul, and carrying within it the particular history of this city. Fez was for centuries home to one of the great Sephardic Jewish communities of the Arab world, and Dar Roumana's kitchen remembers this. The meal began with jamón alongside local ricotta and a fresh nectarine salad — the kind of opening that announces a cook who understands contrast, who knows that sweetness sharpens salt. A chicken dish followed, tender and deeply spiced. And to close: a Sephardic orange and almond cake with crème, dense and fragrant and tasting of somewhere very old. The kind of meal that makes you understand a place in the way that hours of walking cannot quite achieve — through the intelligence of the food, the layering of history on the plate, the accumulated craft of a cuisine that has had twelve centuries to refine itself.</p>\n    <p>Afterward, the traveller climbed to the Marinid Tombs in the last light — the ruined tombs of the dynasty that built much of what makes Fez magnificent, now open to the sky on the hill above the city. From here the entire medina is visible below: a dense, breathing, uncountable mass of ochre rooftops and minarets and the faint blue smoke of evening fires, stretching to the modern city on the far side of the valley. The muezzin called. The swallows turned. The traveller stood and looked for a long time, knowing they could not hold it, knowing they were trying anyway.</p>\n  </div>\n\n  <div class=\"practical narrative\">\n    <div class=\"prac-header\">\n      <span class=\"prac-city\">📍 Fez — Getting There &amp; Around</span>\n    </div>\n    <div class=\"prac-section\">\n      <div class=\"prac-label\">Getting There</div>\n      <div class=\"prac-item\"><strong>By train from Rabat:</strong> ONCF rail from Rabat Ville to Gare de Fès. Journey approximately 2 hours 30 minutes. Comfortable and reliable — second class is perfectly adequate. ~100–120 MAD (AUD $15–18). Trains run frequently throughout the day.</div>\n      <div class=\"prac-item\"><strong>From Marrakech:</strong> Direct train to Fez runs approximately 7–8 hours via Casablanca, or change at Casa Voyageurs. Book ahead on the ONCF website. ~160–200 MAD second class.</div>\n    </div>\n    <div class=\"prac-section\">\n      <div class=\"prac-label\">Getting Around</div>\n      <div class=\"prac-item\"><strong>Inside the medina:</strong> On foot only. No cars, no motorbikes. Donkeys do the heavy lifting. Budget time generously — distances on a map bear no relationship to actual walking time through the alleys.</div>\n      <div class=\"prac-item\"><strong>Getting lost:</strong> Inevitable and not a problem. Stay calm, find a main artery (Talaa Kebira or Talaa Sghira are the two main spines of the medina), or ask a shopkeeper. If someone walks you to your destination, 100–200 MAD is an appropriate and appreciated gesture.</div>\n      <div class=\"prac-item\"><strong>Official guides:</strong> Available through your accommodation. Worth it for the first morning — they unlock context that independent wandering misses. Never engage an unofficial guide without a badge.</div>\n    </div>\n    <div class=\"prac-section\">\n      <div class=\"prac-label\">Tips &amp; Watch-outs</div>\n      <div class=\"tip-row\">Download an offline map before entering the medina. Phone signal is patchy and GPS struggles inside the dense fabric of the old city.</div>\n      <div class=\"tip-row\">Tannery viewing is free through the leather shops — you are expected to look at goods but not obligated to buy. A polite \"shukran\" gets you out gracefully.</div>\n      <div class=\"tip-row\">The medina is at its most atmospheric in the early morning, before 9am, and at dusk. Midday in summer is hot and crowded.</div>\n      <div class=\"tip-row\">Dress modestly. This is a living religious city, not a tourist park. Shoulders and knees covered is the minimum.</div>\n    </div>\n  </div>\n\n</div>\n\n<div class=\"post-closing\">\n  <div class=\"narrative\" style=\"max-width:1100px;margin:0 auto;\">\n    <div class=\"prose\">\n      <p>On the morning of the twenty-third day, the traveller gathered their things in the cool of the dar's patio, the light coming down through the cedar lattice in its usual slanted geometry, and prepared to leave. The train north would depart at a quarter past the eleventh hour. There was time for mint tea and nothing else.</p>\n      <p>Fez is not a city that can be adequately described. The traveller had tried, in the quiet of those evenings on the rooftop, to find the words — and had found instead that the city defeats language by design, that it was built for experience and not for telling, that the only honest thing one can say about Fez el-Bali is that you must go, and that when you go you must surrender the idea that you will understand it, and that in the surrendering something opens that does not close again.</p>\n      <p>The door of Dar Le Petit Bijou shut behind them with its old iron click. The alley absorbed them. And then the alley gave them up, and the city gave them up, and the train took them north toward Tangier, toward the strait, toward the last chapter — but for a long while after, some portion of the traveller remained in those nine thousand alleys, still walking, still lost, still marvelling.</p>\n    </div>\n  </div>\n</div>\n\n<div class=\"itin-block\">\n  <div class=\"itin-inner\">\n    <div class=\"itin-block-title\">The Itinerary at a Glance</div>\n    <div class=\"itin-meta\"><strong>Trip:</strong> Fez, Morocco — Standalone city stay</div>\n    <div class=\"itin-meta\"><strong>Duration:</strong> 2 nights, 2 days</div>\n    <div class=\"itin-meta\"><strong>Best time to go:</strong> March–May or September–November. Avoid July–August (extreme heat inside the medina).</div>\n    <div class=\"itin-meta\"><strong>Arrived from:</strong> Rabat by ONCF train</div>\n\n    <div class=\"itin-section-head\">Day by Day</div>\n    <div class=\"itin-days\">\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 1 — Arrival</span>Train arrives Gare de Fès 14:20. Check in to dar, orientate in the medina. Dinner at Mouda Palace rooftop (book 7:30pm).</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 2 — Full Day</span>Al-Attarine Madrasa at opening. Nejjarine quarter. Chouara Tanneries. Lunch at Ryad Nejjarine. Bou Inania Medersa. Marinid Tombs at dusk. Dinner at Dar Roumana (book 7:30pm).</div>\n      <div class=\"itin-day-row\"><span class=\"itin-day-num\">Day 3 — Departure</span>Check out 10:00. Train departs 11:15. North to Tangier or onward on the imperial circuit.</div>\n    </div>\n\n    <div class=\"itin-section-head\">Total Budget Estimate</div>\n    <div class=\"grand-total-block\">\n      <div class=\"grand-total-grid\">\n        <div class=\"grand-line\"><strong>Accommodation (2 nights)</strong>~$180 AUD</div>\n        <div class=\"grand-line\"><strong>Food &amp; drink</strong>~$130 AUD</div>\n        <div class=\"grand-line\"><strong>Transport (train in)</strong>~$20 AUD</div>\n        <div class=\"grand-line\"><strong>Activities &amp; tips</strong>~$40 AUD</div>\n      </div>\n      <div class=\"grand-total-num\">~$370 AUD total</div>\n    </div>\n\n    <div class=\"itin-section-head\">Quick Reference — Best Eats</div>\n    <div class=\"eats-row\"><div class=\"eats-city\">Dinner</div><div>Mouda Palace — rooftop terrace, traditional Fassi, views over the medina. Book ahead.</div></div>\n    <div class=\"eats-row\"><div class=\"eats-city\">Lunch</div><div>Restaurant Ryad Nejjarine — riad courtyard, tagines, mint tea. Heart of the old medina.</div></div>\n    <div class=\"eats-row\"><div class=\"eats-city\">Dinner</div><div>Dar Roumana — finest table in Fez. Modern Moroccan, 15th-century setting. Book well ahead.</div></div>\n\n    <div class=\"itin-section-head\">Getting Around</div>\n    <div class=\"transport-note\"><strong>Train in:</strong> ONCF from Rabat Ville (~2h30m, ~$18 AUD) or Marrakech via Casablanca (~7–8h, ~$30 AUD).</div>\n    <div class=\"transport-note\"><strong>Inside Fez:</strong> Foot only. No cars in the medina. Download offline maps before you enter.</div>\n    <div class=\"transport-note\"><strong>Getting lost:</strong> Budget 100–200 MAD and accept help graciously. It is part of the experience.</div>\n  </div>\n</div>\n\n<div class=\"faq-block\">\n  <div class=\"faq-inner\">\n    <div class=\"itin-block-title\">Frequently Asked</div>\n\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">How many days do you need in Fez?</div>\n      <div class=\"faq-a\">Two full days is the minimum to do Fez justice. Day one covers Fes el-Jdid — the Royal Palace, the Mellah, the Bab Dekkakin gates. Day two goes deep into Fes el-Bali: the tanneries, Al-Attarine Madrasa, Al-Qarawiyyin, and Bou Inania Medersa. A third day allows for slower wandering, the Marinid Tombs at dusk, and the neighbourhoods the standard route never reaches. If you can afford three days, take them.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Is Fez safe for solo travellers?</div>\n      <div class=\"faq-a\">Fez is generally safe. The medina will disorient you and unofficial guides will approach constantly — a firm but polite decline is all that is needed. If you genuinely get lost, locals are almost universally helpful. Budget 100–200 MAD if someone walks you to a landmark, and accept the assistance without anxiety. The city is used to confused visitors and is kind about it.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">What is the best way to get to Fez from Rabat or Marrakech?</div>\n      <div class=\"faq-a\">The ONCF train is the right answer from both cities. From Rabat Ville the journey takes around two and a half hours and costs approximately 100–120 MAD in second class. From Marrakech, plan for seven to eight hours via Casablanca Voyageurs — book seats in advance online. The trains are reliable, the seats adequate, and the countryside worth watching.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">What does the Chouara Tannery smell like?</div>\n      <div class=\"faq-a\">Ammonia, predominantly — from the pigeon dung used in the leather-curing process, a method unchanged since the eleventh century. It is pungent and unmistakable. It is also completely manageable, and the visual spectacle from the balconies above — the stone vats of saffron, poppy and indigo dye, the hides spread to dry on the surrounding rooftops — is one of the most extraordinary things you will see in Morocco. Do not let the smell deter you.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <div class=\"faq-q\">Where should I stay in Fez?</div>\n      <div class=\"faq-a\">Stay inside Fes el-Bali. The Golden Triangle — the precinct bounded by the Mausoleum of Moulay Idriss, Al-Qarawiyyin University, and the Mausoleum of Sidi Ahmed Tijani — is the ideal location. A traditional dar here puts you inside the living museum rather than outside looking in. <a href=\"https://www.airbnb.com.au/rooms/7023629\" style=\"color:#7db05a;\">Dar Le Petit Bijou</a> is a 14th-century gem and one of the finest small accommodations on the entire Moroccan imperial circuit.</div>\n    </div>\n  </div>\n</div>\n\n<div class=\"next-chronicles\">\n  <div class=\"section-label\">Next Chronicles</div>\n  <div class=\"posts-grid\">\n    <div class=\"post-card\">\n      <div class=\"post-region\">Africa · Morocco</div>\n      <div class=\"post-title\">Marrakech: The Red City and the Road South</div>\n      <div class=\"post-excerpt\">Before Fez there was Marrakech — the Djemaa el-Fna at night, the road to Aït Ben Haddou, and the question of whether any city can really be understood in five days.</div>\n      <div class=\"post-meta\"><span>Morocco</span><span class=\"dot\"></span><span>5 Days</span></div>\n    </div>\n    <div class=\"post-card\">\n      <div class=\"post-region\"><a href=\"/3-days-in-tangier-at-the-edge-of-two-worlds/\" rel=\"history\">Africa · Morocco</a></div>\n      <div class=\"post-title\">Tangier: The City at the Edge of Everything</div>\n      <div class=\"post-excerpt\">The strait is visible from the Kasbah. Spain is fourteen kilometres across the water. Tangier has always known it lives at a crossing point — and has never stopped performing that knowledge.</div>\n      <div class=\"post-meta\"><span>Morocco</span><span class=\"dot\"></span><span>2 Days</span></div>\n    </div>\n    <div class=\"post-card\">\n      <div class=\"post-region\"><a href=\"/the-imperial-circuit-morocco-in-14-days/\" rel=\"history\">Africa · Morocco</a></div>\n      <div class=\"post-title\">The Morocco Imperial Circuit: 14 Days Through the Four Royal Cities</div>\n      <div class=\"post-excerpt\">Marrakech to Rabat to Fez to Tangier — the full route through Morocco's imperial heartland, with costs, transport, and the best meals along the way.</div>\n      <div class=\"post-meta\"><span>Morocco</span><span class=\"dot\"></span><span>14 Days</span></div>\n    </div>\n  </div>\n</div></bodycopy></div></div></div></div>";
